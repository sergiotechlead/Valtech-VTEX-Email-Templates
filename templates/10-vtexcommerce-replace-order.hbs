<!DOCTYPE html>
<html lang="fr" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>CHANEL – Votre nouvelle commande est confirmée</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:AllowPNG/>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style type="text/css">

  body,table,td,p,a,li{-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;}
  body,td,th,input,textarea,select,p,span{font-family:Arial,ArialMT,Helvetica,sans-serif;}
  table,td{mso-table-lspace:0pt;mso-table-rspace:0pt;}
  img{-ms-interpolation-mode:bicubic;border:0;outline:none;text-decoration:none;}
  body{margin:0;padding:0;background-color:#f9f9f9;}
  .email-wrapper{width:100%;background-color:#f9f9f9;}
  .email-container{max-width:640px;margin:0 auto;background-color:#ffffff;}
  .top-bar{height:7px;background-color:#000000;max-width:640px;margin:0 auto;}
  h1{font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 20px;line-height:1.4;}
  h2{font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;color:#000000;text-transform:uppercase;letter-spacing:0.7px;margin:28px 0 12px;line-height:1.4;}
  p{font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;line-height:23px;margin:0 0 14px;}
  a{color:#1d1d1d;text-decoration:underline;}
  .product-table{width:100%;border-collapse:collapse;}
  .product-table th{font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.7px;color:#000000;padding:8px 0;border-bottom:2px solid #000000;text-align:left;}
  .product-table th.right{text-align:right;}
  .product-table td{font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;padding:12px 0;border-bottom:1px solid #eeeeee;vertical-align:top;}
  .product-table td.right{text-align:right;}
  .totals-table{width:100%;border-collapse:collapse;margin-top:20px;}
  .totals-table td{font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;padding:6px 0;}
  .totals-table td.right{text-align:right;}
  .totals-table tr.total-row td{font-weight:700;color:#000000;border-top:1px solid #000000;padding-top:10px;}
  .address-box{background-color:#f9f9f9;padding:20px;margin:0 0 28px;}
  .address-box p{margin:0;font-size:14px;line-height:22px;color:#333333;}
  .estimate-box{background-color:#f9f9f9;padding:16px 20px;margin:0 0 28px;}
  .btn-primary{display:inline-block;background-color:#000000;color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:1px;text-decoration:none;padding:14px 32px;}
  .code-box{background-color:#f9f9f9;text-align:center;padding:16px 20px;margin:24px 0;}
  .code-box p{font-family:Arial,Helvetica,sans-serif;font-size:40px;letter-spacing:20px;color:#000000;margin:0;padding-left:20px;}
  .divider{border:none;border-top:1px solid #eeeeee;margin:28px 0;}
  .help-section{border-top:1px solid #eeeeee;padding-top:28px;margin-top:28px;}
  .footer-table{max-width:640px;margin:0 auto;background-color:#000000;}
  .footer-heading{font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.7px;color:#ffffff;margin:0 0 12px;}
  .footer-link{font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#9b9b9b;text-decoration:none;line-height:26px;}
  .footer-link-white{font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#ffffff;text-decoration:none;line-height:26px;}
  .footer-legal{font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#9b9b9b;line-height:20px;text-align:center;}
  .footer-legal a{color:#9b9b9b;text-decoration:underline;}
  @media only screen and (max-width:640px){
    .email-container{width:100%!important;}
    .footer-col{width:100%!important;display:block!important;padding:0 0 20px 0!important;}
    .content-padding{padding:20px!important;}
    h1{font-size:18px!important;}
  }

  </style>
</head>
<body style="margin:0;padding:0;background-color:#f9f9f9;">
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="width:100%;background-color:#f9f9f9;" class="email-wrapper">
    <tr>
      <td>

  <!-- TOP BAR -->
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#000000;max-width:640px;margin:0 auto;">
    <tr><td style="height:7px;font-size:7px;line-height:7px;">&nbsp;</td></tr>
  </table>
  <!-- LOGO HEADER -->
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width:640px;margin:0 auto;background-color:#ffffff;">
    <tr>
      <td align="center" style="padding:36px 40px 30px;background-color:#ffffff;">
        <a href="https://www.chanel.com/fr/" style="text-decoration:none;border:0;display:inline-block;" target="_blank" aria-label="Page d'accueil CHANEL">
          <svg xmlns="http://www.w3.org/2000/svg" width="175" height="28" viewBox="0 0 175 28" role="img" aria-label="CHANEL"><title>CHANEL</title><path fill="#000000" fill-rule="evenodd" d="m20.655 17.726 4.565 2.615c-2.282 4.197-6.737 6.922-11.781 6.922C6.075 27.263 0 21.629 0 13.713S6.075.163 13.439.163c5.044 0 9.5 2.725 11.781 6.923L20.655 9.7c-1.326-2.725-4.013-4.381-7.216-4.381-4.603 0-8.1 3.423-8.1 8.394s3.497 8.395 8.1 8.395c3.203 0 5.89-1.657 7.216-4.382m29.05 8.874V15.554H36.818V26.6h-5.154V.826h5.154V10.4h12.887V.826h5.155V26.6zm29.898-10.678L74.926 5.061 70.25 15.922zM89.838 26.6h-5.634l-2.54-5.892H68.188l-2.54 5.892h-5.634L71.428.826h6.996zm23.748 0L99.778 6.313V26.6h-4.786V.826h6.812l11.598 17.084V.826h4.787V26.6zm14.543 0V.826h18.41v4.787h-13.624v5.523h11.782v4.786h-11.782v5.892h14.36V26.6zm27.431 0V.826h5.154v20.62h13.622V26.6z"/></svg>
        </a>
      </td>
    </tr>
  </table>
        <!-- MAIN CONTENT -->
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width:640px;margin:0 auto;background-color:#ffffff;">
          <tr>
            <td style="padding:0 40px 40px;" class="content-padding">

              <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top:36px;">
                <tr>
                  <td>
                    {{#if orders.0.clientProfileData.firstName}}
                    {{! Greeting orders.0 firstName }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Hello {{orders.0.clientProfileData.firstName}},</h1>{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Dzień dobry {{orders.0.clientProfileData.firstName}},</h1>{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Ciao {{orders.0.clientProfileData.firstName}},</h1>{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Guten Tag {{orders.0.clientProfileData.firstName}},</h1>{{else}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Bonjour {{orders.0.clientProfileData.firstName}},</h1>{{/compare}}{{/compare}}{{/compare}}{{/compare}}
                    {{else}}
                    {{! Default greeting }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Dear Customer,</h1>{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Drogi Kliencie,</h1>{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Gentile cliente,</h1>{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Sehr geehrter Kunde,</h1>{{else}}<h1 style="font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:400;color:#1d1d1d;margin:0 0 16px;line-height:1.4;">Cher client,</h1>{{/compare}}{{/compare}}{{/compare}}{{/compare}}
                    {{/if}}
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;line-height:23px;margin:0 0 14px;">
                      {{! Body paragraph replace order }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Your replacement order has been recorded. We are currently processing it with the utmost care.{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Twoje zamówienie zastępcze zostało zarejestrowane. Obecnie przetwarzamy je z największą starannością.{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Il suo ordine sostitutivo è stato registrato. Lo stiamo attualmente elaborando con la massima cura.{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Ihre Ersatzbestellung wurde erfasst. Wir bearbeiten sie derzeit mit größter Sorgfalt.{{else}}Votre commande de remplacement a bien été enregistrée. Nous la traitons actuellement avec la plus grande attention.{{/compare}}{{/compare}}{{/compare}}{{/compare}}
                    </p>
                    {{#if orders.0.orderId}}
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;line-height:23px;margin:0 0 28px;">
                      {{! Order number label }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}<strong style="color:#000000;">Order No.:</strong>{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}<strong style="color:#000000;">Nr zamówienia:</strong>{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}<strong style="color:#000000;">N° ordine:</strong>{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}<strong style="color:#000000;">Bestellnummer:</strong>{{else}}<strong style="color:#000000;">N° de commande :</strong>{{/compare}}{{/compare}}{{/compare}}{{/compare}} {{orders.0.orderId}}
                    </p>
                    {{/if}}
                  </td>
                </tr>
              </table>
              
        {{#if orders.0.items}}
        <h2 style="font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;color:#000000;text-transform:uppercase;letter-spacing:0.7px;margin:28px 0 12px;">{{! Section ordered items }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Ordered Items{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Zamówione artykuły{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Articoli ordinati{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Bestellte Artikel{{else}}Articles commandés{{/compare}}{{/compare}}{{/compare}}{{/compare}}</h2>
        <table role="presentation" class="product-table" width="100%" border="0" cellspacing="0" cellpadding="0" style="width:100%;border-collapse:collapse;">
          <thead>
            <tr>
              <th style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.7px;color:#000000;padding:8px 0;border-bottom:2px solid #000000;text-align:left;">{{! TH item }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Item{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Artykuł{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Articolo{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Artikel{{else}}Article{{/compare}}{{/compare}}{{/compare}}{{/compare}}</th>
              <th style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.7px;color:#000000;padding:8px 6px;border-bottom:2px solid #000000;text-align:center;">{{! TH qty }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Qty{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Ilość{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Qtà{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Menge{{else}}Qté{{/compare}}{{/compare}}{{/compare}}{{/compare}}</th>
              <th style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.7px;color:#000000;padding:8px 0;border-bottom:2px solid #000000;text-align:right;">{{! TH price }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Price{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Cena{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Prezzo{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Preis{{else}}Prix{{/compare}}{{/compare}}{{/compare}}{{/compare}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each orders.0.items}}
            <tr>
              <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;padding:12px 0;border-bottom:1px solid #eeeeee;vertical-align:top;">{{name}}</td>
              <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;padding:12px 6px;border-bottom:1px solid #eeeeee;vertical-align:top;text-align:center;">{{quantity}}</td>
              <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;padding:12px 0;border-bottom:1px solid #eeeeee;vertical-align:top;text-align:right;white-space:nowrap;">{{formatCurrency sellingPrice}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{/if}}
              
        {{#if orders.0.totals}}
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="width:100%;border-collapse:collapse;margin-top:16px;">
          {{#each orders.0.totals}}
          {{#if value}}
          <tr>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;padding:5px 0;text-align:left;">{{name}}</td>
            <td style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;padding:5px 0;text-align:right;white-space:nowrap;">{{formatCurrency value}}</td>
          </tr>
          {{/if}}
          {{/each}}
        </table>
        {{/if}}
              
        {{#if orders.0.shippingData.address}}
        <h2 style="font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;color:#000000;text-transform:uppercase;letter-spacing:0.7px;margin:28px 0 12px;">{{! Section shipping address }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Delivery Address{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Adres dostawy{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Indirizzo di consegna{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Lieferadresse{{else}}Adresse de livraison{{/compare}}{{/compare}}{{/compare}}{{/compare}}</h2>
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#f9f9f9;margin-bottom:28px;">
          <tr>
            <td style="padding:16px 20px;">
              {{#if orders.0.shippingData.address.receiverName}}
              <p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;line-height:22px;margin:0;"><strong style="color:#000000;">{{orders.0.shippingData.address.receiverName}}</strong></p>
              {{/if}}
              <p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;line-height:22px;margin:4px 0 0;">
                {{orders.0.shippingData.address.street}}{{#if orders.0.shippingData.address.number}}, {{orders.0.shippingData.address.number}}{{/if}}<br>
                {{#if orders.0.shippingData.address.complement}}{{orders.0.shippingData.address.complement}}<br>{{/if}}
                {{orders.0.shippingData.address.postalCode}} {{orders.0.shippingData.address.city}}<br>
                {{orders.0.shippingData.address.country}}
              </p>
            </td>
          </tr>
        </table>
        {{/if}}
              
        {{#if orders.0.shippingData.logisticsInfo}}
        <h2 style="font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;color:#000000;text-transform:uppercase;letter-spacing:0.7px;margin:28px 0 12px;">{{! Section estimated delivery }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Estimated Delivery Time{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Szacowany czas dostawy{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Tempo di consegna stimato{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Geschätzte Lieferzeit{{else}}Délai de livraison estimé{{/compare}}{{/compare}}{{/compare}}{{/compare}}</h2>
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#f9f9f9;margin-bottom:28px;">
          <tr>
            <td style="padding:16px 20px;">
              {{#each orders.0.shippingData.logisticsInfo}}
              {{#each slas}}
              {{#if (eq ../selectedSla id)}}
              <p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;line-height:22px;margin:0 0 6px;"><strong style="color:#000000;">{{name}}</strong></p>
              {{#if deliveryWindow}}
              <p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;line-height:22px;margin:0;">
                {{! Delivery window }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Scheduled delivery on {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} between {{formatDate deliveryWindow.startDateUtc "HH:mm"}} and {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Planowana dostawa {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} między {{formatDate deliveryWindow.startDateUtc "HH:mm"}} a {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Consegna prevista il {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} tra le {{formatDate deliveryWindow.startDateUtc "HH:mm"}} e le {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Geplante Lieferung am {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} zwischen {{formatDate deliveryWindow.startDateUtc "HH:mm"}} und {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{else}}Livraison prévue le {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} entre {{formatDate deliveryWindow.startDateUtc "HH:mm"}} et {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{/compare}}{{/compare}}{{/compare}}{{/compare}}
              </p>
              {{else}}
              <p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#333333;line-height:22px;margin:0;">
                {{! Delivery estimate }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Estimated delivery: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} working day(s){{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Szacowany termin dostawy: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} dzień(dni) roboczy(ch){{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Consegna stimata: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} giorno(i) lavorativo(i){{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Geschätzte Lieferung: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} Werktag(e){{else}}Livraison estimée&nbsp;: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} jour(s) ouvré(s){{/compare}}{{/compare}}{{/compare}}{{/compare}}
              </p>
              {{/if}}
              {{/if}}
              {{/each}}
              {{/each}}
            </td>
          </tr>
        </table>
        {{/if}}

        <!-- HELP -->
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top:28px;border-top:1px solid #eeeeee;">
          <tr><td style="height:28px;">&nbsp;</td></tr>
          <tr>
            <td>
              <h2 style="font-family:Arial,Helvetica,sans-serif;font-size:12px;font-weight:700;color:#000000;text-transform:uppercase;letter-spacing:0.7px;margin:0 0 12px;">{{! Help heading }}
{{#compare orders.0.clientPreferencesData.locale "==" "en-GB"}}Need help?{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "pl-PL"}}Potrzebujesz pomocy?{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "it-IT"}}Hai bisogno di aiuto?{{else}}{{#compare orders.0.clientPreferencesData.locale "==" "de-DE"}}Benötigen Sie Hilfe?{{else}}Besoin d'aide ?{{/compare}}{{/compare}}{{/compare}}{{/compare}}</h2>
