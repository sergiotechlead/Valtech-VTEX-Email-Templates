  <style type="text/css">

  /* ============================================================
     CHANEL Email Templates — Design System
     ============================================================

     COLOR TOKENS
     Brand Black   : #000000
     Text Dark     : #1d1d1d
     Text Body     : #333333
     Text Muted    : #9b9b9b
     Background    : #f9f9f9
     White         : #ffffff
     Border Light  : #eeeeee
     Border Dark   : #333333
  */

  /* --- Reset ------------------------------------------------- */
  body,table,td,p,a,li { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
  body,td,th,input,textarea,select,p,span { font-family:Arial,ArialMT,Helvetica,sans-serif; }
  table,td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
  img { -ms-interpolation-mode:bicubic; border:0; outline:none; text-decoration:none; }

  /* --- Layout ------------------------------------------------ */
  body             { margin:0; padding:0; background-color:#f9f9f9; }
  .email-wrapper   { width:100%; background-color:#f9f9f9; }
  .email-container { max-width:640px; margin:0 auto; background-color:#ffffff; }

  /* --- Typography -------------------------------------------- */
  h1 {
    font-family: Arial, Helvetica, sans-serif;
    font-size:   22px;
    font-weight: 400;
    color:       #1d1d1d;
    margin:      0 0 16px;
    line-height: 1.4;
  }
  h2 {
    font-family:    Arial, Helvetica, sans-serif;
    font-size:      12px;
    font-weight:    700;
    color:          #000000;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin:         28px 0 12px;
    line-height:    1.4;
  }
  p {
    font-family: Arial, Helvetica, sans-serif;
    font-size:   14px;
    color:       #333333;
    line-height: 23px;
    margin:      0 0 27px;
  }
  a      { color:#1d1d1d; text-decoration:underline; }
  strong { color:#000000; }

  .h2-flush { margin-top:0; }
  .p-muted   { font-size:11px; color:#9b9b9b; line-height:20px; margin:0; }
  .p-muted a { color:#9b9b9b; }

  /* --- Info panels ------------------------------------------- */
  .info-box       { background-color:#f9f9f9; margin-bottom:28px; }
  .info-box td    { padding:16px 20px; }
  .info-box p     { font-family:Arial,Helvetica,sans-serif; font-size:14px; color:#333333; line-height:22px; margin:0; }
  .info-box p + p { margin-top:6px; }

  /* --- Security notice box ----------------------------------- */
  .security-box    { background-color:#f9f9f9; border-left:3px solid #000000; margin-bottom:28px; }
  .security-box td { padding:16px 20px; }
  .security-box p  { font-family:Arial,Helvetica,sans-serif; font-size:14px; color:#333333; line-height:22px; margin:0; }

  /* --- CTA button -------------------------------------------- */
  .btn-primary { display:inline-block; background-color:#000000; color:#ffffff; font-family:Arial,Helvetica,sans-serif; font-size:14px; font-weight:700; text-transform:uppercase; letter-spacing:1px; text-decoration:none; padding:14px 32px; }

  /* --- Help section ------------------------------------------ */
  .help-section    { margin-top:28px; border-top:1px solid #eeeeee; }
  .help-section td { height:28px; }

  /* --- Footer ------------------------------------------------ */
  .footer-nav-list    { font-size:14px; line-height:22px; padding:0; margin:0; color:#9b9b9b; list-style-type:none; }
  .footer-nav-list li { margin-bottom:9px; }
  .footer-nav-list a  { text-decoration:none; color:#9b9b9b; }
  .footer-legal       { color:#9b9b9b; font-size:12px; text-align:center; line-height:16px; }
  .footer-legal p     { font-size:12px; color:#9b9b9b; margin-bottom:3px; }
  .footer-legal a     { color:#9b9b9b; }

  /* --- Responsive ------------------------------------------- */
  @media only screen and (max-width:640px) {
    .email-container { width:100%!important; }
    .footer-col      { width:100%!important; display:block!important; padding:0 0 20px 0!important; }
    .content-padding { padding:10px!important; }
    h1               { font-size:18px!important; }
  }

  </style>
</head>
<body style="margin:0;padding:0;background-color:#f9f9f9;">
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="width:100%;background-color:#f9f9f9;" class="email-wrapper">
    <tr>
      <td>

  <!-- TOP BAR -->
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#000000;max-width:640px;margin:0 auto;">
    <tr><td style="height:7px;font-size:7px;line-height:7px;">&nbsp;</td></tr>
  </table>

  <!-- LOGO HEADER -->
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width:640px;margin:0 auto;background-color:#ffffff;">
    <tr>
      <td align="center" style="padding:36px 40px 30px;background-color:#ffffff;">
        <img src="https://img-mail.chanel.com/1563281382415-chanel_black.png" alt="CHANEL" width="175" height="28" style="display:block;border:0;outline:none;text-decoration:none;">
      </td>
    </tr>
  </table>

        <!-- MAIN CONTENT -->
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width:640px;margin:0 auto;background-color:#ffffff;">
          <tr>
            <td style="padding:0 10px 10px;background-color:#ffffff;" class="content-padding">

              <!-- GREETING -->
              <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top:36px;">
                <tr>
                  <td>
                    {{#if userName}}
{{#compare locale "==" "pl-PL"}}<h1>Dzień dobry {{userName}},</h1>{{else}}{{#compare locale "==" "it-IT"}}<h1>Ciao {{userName}},</h1>{{else}}{{#compare locale "==" "de-DE"}}<h1>Guten Tag {{userName}},</h1>{{else}}<h1>Bonjour {{userName}},</h1>{{/compare}}{{/compare}}{{/compare}}
                    {{else}}
{{#compare locale "==" "pl-PL"}}<h1>Drogi Kliencie,</h1>{{else}}{{#compare locale "==" "it-IT"}}<h1>Gentile cliente,</h1>{{else}}{{#compare locale "==" "de-DE"}}<h1>Sehr geehrter Kunde,</h1>{{else}}<h1>Cher client,</h1>{{/compare}}{{/compare}}{{/compare}}
                    {{/if}}

                    <!-- BODY MESSAGE -->
                    <p>
{{#compare locale "==" "pl-PL"}}Wykryliśmy nowe logowanie do Twojego konta <strong>{{_accountInfo.TradingName}}</strong>. Jeśli to Ty, nie jest wymagane żadne działanie.{{else}}{{#compare locale "==" "it-IT"}}Abbiamo rilevato un nuovo accesso al tuo account <strong>{{_accountInfo.TradingName}}</strong>. Se eri tu, non è richiesta alcuna azione.{{else}}{{#compare locale "==" "de-DE"}}Wir haben eine neue Anmeldung bei Ihrem <strong>{{_accountInfo.TradingName}}</strong>-Konto erkannt. Wenn Sie das waren, ist keine Aktion erforderlich.{{else}}Nous avons détecté une nouvelle connexion à votre compte <strong>{{_accountInfo.TradingName}}</strong>. Si c'était bien vous, aucune action n'est requise.{{/compare}}{{/compare}}{{/compare}}
                    </p>
                  </td>
                </tr>
              </table>

              <!-- SIGN-IN DETAILS PANEL -->
              <h2>{{#compare locale "==" "pl-PL"}}Szczegóły logowania{{else}}{{#compare locale "==" "it-IT"}}Dettagli dell'accesso{{else}}{{#compare locale "==" "de-DE"}}Anmeldedetails{{else}}Détails de la connexion{{/compare}}{{/compare}}{{/compare}}</h2>
              <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" class="info-box">
                <tr>
                  <td>
                    {{#if time}}
                    <p>
                      {{#compare locale "==" "pl-PL"}}<strong>Godzina:</strong>{{else}}{{#compare locale "==" "it-IT"}}<strong>Ora:</strong>{{else}}{{#compare locale "==" "de-DE"}}<strong>Uhrzeit:</strong>{{else}}<strong>Heure :</strong>{{/compare}}{{/compare}}{{/compare}} {{time}}
                    </p>
                    {{/if}}
                    {{#if signInTime}}
                    <p>
                      {{#compare locale "==" "pl-PL"}}<strong>Godzina:</strong>{{else}}{{#compare locale "==" "it-IT"}}<strong>Ora:</strong>{{else}}{{#compare locale "==" "de-DE"}}<strong>Uhrzeit:</strong>{{else}}<strong>Heure :</strong>{{/compare}}{{/compare}}{{/compare}} {{signInTime}}
                    </p>
                    {{/if}}
                    {{#if ipAddress}}
                    <p>
                      {{#compare locale "==" "pl-PL"}}<strong>Adres IP:</strong>{{else}}{{#compare locale "==" "it-IT"}}<strong>Indirizzo IP:</strong>{{else}}{{#compare locale "==" "de-DE"}}<strong>IP-Adresse:</strong>{{else}}<strong>Adresse IP :</strong>{{/compare}}{{/compare}}{{/compare}} {{ipAddress}}
                    </p>
                    {{/if}}
                    {{#if deviceInfo}}
                    <p>
                      {{#compare locale "==" "pl-PL"}}<strong>Urządzenie:</strong>{{else}}{{#compare locale "==" "it-IT"}}<strong>Dispositivo:</strong>{{else}}{{#compare locale "==" "de-DE"}}<strong>Gerät:</strong>{{else}}<strong>Appareil :</strong>{{/compare}}{{/compare}}{{/compare}} {{deviceInfo}}
                    </p>
                    {{/if}}
                    {{#if location}}
                    <p>
                      {{#compare locale "==" "pl-PL"}}<strong>Lokalizacja:</strong>{{else}}{{#compare locale "==" "it-IT"}}<strong>Posizione:</strong>{{else}}{{#compare locale "==" "de-DE"}}<strong>Standort:</strong>{{else}}<strong>Lieu :</strong>{{/compare}}{{/compare}}{{/compare}} {{location}}
                    </p>
                    {{/if}}
                    {{#if tenant}}
                    <p>
                      {{#compare locale "==" "pl-PL"}}<strong>Konto:</strong>{{else}}{{#compare locale "==" "it-IT"}}<strong>Account:</strong>{{else}}{{#compare locale "==" "de-DE"}}<strong>Konto:</strong>{{else}}<strong>Compte :</strong>{{/compare}}{{/compare}}{{/compare}} {{tenant}}
                    </p>
                    {{/if}}
                    {{#if userEmail}}
                    <p>
                      {{#compare locale "==" "pl-PL"}}<strong>E-mail:</strong>{{else}}{{#compare locale "==" "it-IT"}}<strong>E-mail:</strong>{{else}}{{#compare locale "==" "de-DE"}}<strong>E-Mail:</strong>{{else}}<strong>E-mail :</strong>{{/compare}}{{/compare}}{{/compare}} {{userEmail}}
                    </p>
                    {{/if}}
                  </td>
                </tr>
              </table>

              <!-- SECURITY NOTICE -->
              <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" class="security-box">
                <tr>
                  <td>
                    <p>
                      {{#compare locale "==" "pl-PL"}}Jeśli to nie Ty, prosimy o natychmiastowe zresetowanie hasła w celu zabezpieczenia konta.{{else}}{{#compare locale "==" "it-IT"}}Se non eri tu, ti invitiamo a reimpostare immediatamente la password per proteggere il tuo account.{{else}}{{#compare locale "==" "de-DE"}}Wenn Sie das nicht waren, laden wir Sie ein, Ihr Passwort unverzüglich zurückzusetzen, um Ihr Konto zu schützen.{{else}}Si ce n'était pas vous, nous vous invitons à réinitialiser votre mot de passe sans délai afin de sécuriser votre compte.{{/compare}}{{/compare}}{{/compare}}
                    </p>
                  </td>
                </tr>
              </table>

              <!-- RESET PASSWORD CTA -->
