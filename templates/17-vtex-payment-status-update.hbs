  <style type="text/css">

  /* ============================================================
     CHANEL Email Templates — Design System
     Edit ONLY this <style> block to update all visual properties.
     ============================================================

     COLOR TOKENS
     Brand Black   : #000000   (buttons, borders, headings)
     Text Dark     : #1d1d1d   (greeting h1, body links)
     Text Body     : #333333   (paragraphs, table cells)
     Text Muted    : #9b9b9b   (footer, legal notices)
     Background    : #f9f9f9   (page bg, info panels)
     White         : #ffffff   (email body)
     Border Light  : #eeeeee   (row dividers)
     Border Dark   : #333333   (footer divider)

     TYPOGRAPHY
     Font stack    : Arial, Helvetica, sans-serif
     H1 size       : 22px  (mobile: 18px)
     H2 size       : 12px  uppercase, letter-spacing 0.7px
     Body size     : 14px  line-height 23px
     Small / legal : 11px  line-height 20px

     SPACING
     Section gap   : 28px
     Info panel    : 16px 20px
     Content pad   : 0 40px 40px
  */

  /* --- Reset ------------------------------------------------- */
  body,table,td,p,a,li { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
  body,td,th,input,textarea,select,p,span { font-family:Arial,ArialMT,Helvetica,sans-serif; }
  table,td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
  img { -ms-interpolation-mode:bicubic; border:0; outline:none; text-decoration:none; }

  /* --- Layout ------------------------------------------------ */
  body             { margin:0; padding:0; background-color:#f9f9f9; }
  .email-wrapper   { width:100%; background-color:#f9f9f9; }
  .email-container { max-width:640px; margin:0 auto; background-color:#ffffff; }

  /* --- Typography -------------------------------------------- */
  h1 {
    font-family: Arial, Helvetica, sans-serif;
    font-size:   22px;
    font-weight: 400;
    color:       #1d1d1d;
    margin:      0 0 16px;
    line-height: 1.4;
  }
  h2 {
    font-family:    Arial, Helvetica, sans-serif;
    font-size:      12px;
    font-weight:    700;
    color:          #000000;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin:         28px 0 12px;
    line-height:    1.4;
  }
  p {
    font-family: Arial, Helvetica, sans-serif;
    font-size:   14px;
    color:       #333333;
    line-height: 23px;
    margin:      0 0 27px;
  }
  a      { color:#1d1d1d; text-decoration:underline; }
  strong { color:#000000; }

  /* h2 variant — flush top (used inside the help section) */
  .h2-flush { margin-top:0; }

  /* Small muted text — privacy & legal notices */
  .p-muted   { font-size:11px; color:#9b9b9b; line-height:20px; margin:0; }
  .p-muted a { color:#9b9b9b; }

  /* --- Product table ----------------------------------------- */
  .product-table              { width:100%; border-collapse:collapse; }
  .product-table th           { font-family:Arial,Helvetica,sans-serif; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.7px; color:#000000; padding:8px 0; border-bottom:2px solid #000000; text-align:left; }
  .product-table th.col-qty   { padding:8px 6px; text-align:center; }
  .product-table th.col-price { text-align:right; }
  .product-table td           { font-family:Arial,Helvetica,sans-serif; font-size:14px; color:#333333; padding:12px 0; border-bottom:1px solid #eeeeee; vertical-align:top; }
  .product-table td.col-qty   { padding:12px 6px; text-align:center; }
  .product-table td.col-price { text-align:right; white-space:nowrap; }

  /* --- Totals table ------------------------------------------ */
  .totals-table              { width:100%; border-collapse:collapse; margin-top:16px; }
  .totals-table td           { font-family:Arial,Helvetica,sans-serif; font-size:14px; color:#333333; padding:5px 0; }
  .totals-table td.col-price { text-align:right; white-space:nowrap; }
  .totals-table .total-row td { font-weight:700; color:#000000; border-top:1px solid #000000; padding-top:10px; }

  /* --- Info panels (shipping address, payment, delivery) ----- */
  .info-box    { background-color:#f9f9f9; margin-bottom:28px; }
  .info-box td { padding:16px 20px; }
  .info-box p  { font-family:Arial,Helvetica,sans-serif; font-size:14px; color:#333333; line-height:22px; margin:0; }

  /* --- CTA button -------------------------------------------- */
  .btn-primary { display:inline-block; background-color:#000000; color:#ffffff; font-family:Arial,Helvetica,sans-serif; font-size:14px; font-weight:700; text-transform:uppercase; letter-spacing:1px; text-decoration:none; padding:14px 32px; }

  /* --- Verification code box --------------------------------- */
  .code-box    { background-color:#f9f9f9; text-align:center; margin:24px 0; }
  .code-box td { padding:16px 20px; text-align:center; }
  .code-box p  { font-family:Arial,Helvetica,sans-serif; font-size:40px; letter-spacing:20px; color:#000000; margin:0; padding-left:20px; line-height:1.4; }

  /* --- Help section ------------------------------------------ */
  .help-section    { margin-top:28px; border-top:1px solid #eeeeee; }
  .help-section td { height:28px; }

  /* --- Footer ------------------------------------------------ */
  .footer-nav-list    { font-size:14px; line-height:22px; padding:0; margin:0; color:#9b9b9b; list-style-type:none; }
  .footer-nav-list li { margin-bottom:9px; }
  .footer-nav-list a  { text-decoration:none; color:#9b9b9b; }
  .footer-legal       { color:#9b9b9b; font-size:12px; text-align:center; line-height:16px; }
  .footer-legal p     { font-size:12px; color:#9b9b9b; margin-bottom:3px; }
  .footer-legal a     { color:#9b9b9b; }

  /* --- Responsive ------------------------------------------- */
  @media only screen and (max-width:640px) {
    .email-container { width:100%!important; }
    .footer-col      { width:100%!important; display:block!important; padding:0 0 20px 0!important; }
    .content-padding { padding:10px!important; }
    h1               { font-size:18px!important; }
  }

  </style>
</head>
<body style="margin:0;padding:0;background-color:#f9f9f9;">
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="width:100%;background-color:#f9f9f9;" class="email-wrapper">
    <tr>
      <td>

  <!-- TOP BAR -->
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#000000;max-width:640px;margin:0 auto;">
    <tr><td style="height:7px;font-size:7px;line-height:7px;">&nbsp;</td></tr>
  </table>
  <!-- LOGO HEADER -->
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width:640px;margin:0 auto;background-color:#ffffff;">
    <tr>
      <td align="center" style="padding:36px 40px 30px;background-color:#ffffff;">
        <img src="https://img-mail.chanel.com/1563281382415-chanel_black.png" alt="CHANEL" width="175" height="28" style="display:block;border:0;outline:none;text-decoration:none;">
      </td>
    </tr>
  </table>

  <!-- MAIN CONTENT -->
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width:640px;margin:0 auto;background-color:#ffffff;">
    <tr>
      <td style="padding:0 10px 10px;background-color:#ffffff;" class="content-padding">

        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top:36px;">
          <tr>
            <td>
              {{! Customer greeting using firstName from orders.0.clientProfileData }}
              {{#if orders.0.clientProfileData.lastName}}
{{#compare orders.0.openTextField.language "==" "pl"}}<p style="margin-bottom:30px;">Szanowny/a Panie/Pani {{orders.0.clientProfileData.lastName}},</p>{{else}}{{#compare orders.0.openTextField.language "==" "it"}}<p style="margin-bottom:30px;">Gentile Sig./Sig.ra {{orders.0.clientProfileData.lastName}},</p>{{else}}{{#compare orders.0.openTextField.language "==" "de"}}<p style="margin-bottom:30px;">Sehr geehrte/r Herr/Frau {{orders.0.clientProfileData.lastName}},</p>{{else}}<p style="margin-bottom:30px;">Cher/Chère M. {{orders.0.clientProfileData.lastName}},</p>{{/compare}}{{/compare}}{{/compare}}
              {{else}}{{#if orders.0.clientProfileData.firstName}}
{{#compare orders.0.openTextField.language "==" "pl"}}<p style="margin-bottom:30px;">Szanowny/a Panie/Pani {{orders.0.clientProfileData.firstName}},</p>{{else}}{{#compare orders.0.openTextField.language "==" "it"}}<p style="margin-bottom:30px;">Gentile Sig./Sig.ra {{orders.0.clientProfileData.firstName}},</p>{{else}}{{#compare orders.0.openTextField.language "==" "de"}}<p style="margin-bottom:30px;">Sehr geehrte/r Herr/Frau {{orders.0.clientProfileData.firstName}},</p>{{else}}<p style="margin-bottom:30px;">Cher/Chère {{orders.0.clientProfileData.firstName}},</p>{{/compare}}{{/compare}}{{/compare}}
              {{else}}
{{#compare orders.0.openTextField.language "==" "pl"}}<p style="margin-bottom:30px;">Szanowny/a Kliencie,</p>{{else}}{{#compare orders.0.openTextField.language "==" "it"}}<p style="margin-bottom:30px;">Gentile Cliente,</p>{{else}}{{#compare orders.0.openTextField.language "==" "de"}}<p style="margin-bottom:30px;">Sehr geehrte/r Kunde/Kundin,</p>{{else}}<p style="margin-bottom:30px;">Cher Client,</p>{{/compare}}{{/compare}}{{/compare}}
              {{/if}}{{/if}}

              <p>
                {{! Body paragraph payment status update }}
{{#compare orders.0.openTextField.language "==" "pl"}}Informujemy, że status Twojej płatności uległ zmianie. Poniżej znajdziesz szczegółowe informacje dotyczące aktualizacji.{{else}}{{#compare orders.0.openTextField.language "==" "it"}}La informiamo che lo stato del suo pagamento è stato aggiornato. Di seguito troverà le informazioni dettagliate relative all'aggiornamento.{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Wir informieren Sie darüber, dass sich der Status Ihrer Zahlung geändert hat. Nachfolgend finden Sie die detaillierten Informationen zur Aktualisierung.{{else}}Nous vous informons que le statut de votre paiement a été mis à jour. Vous trouverez ci-dessous les informations détaillées relatives à cette mise à jour.{{/compare}}{{/compare}}{{/compare}}
              </p>

              {{! Payment status details info box }}
              <h2 class="h2-flush">{{! Section payment status }}
{{#compare orders.0.openTextField.language "==" "pl"}}Szczegóły płatności{{else}}{{#compare orders.0.openTextField.language "==" "it"}}Dettagli del pagamento{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Zahlungsdetails{{else}}Détails du paiement{{/compare}}{{/compare}}{{/compare}}</h2>
              <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" class="info-box">
                <tr>
                  <td>
                    {{#if orders.0.sellers.0.name}}
                    <p style="margin-bottom:6px;">
                      {{! Seller label }}
{{#compare orders.0.openTextField.language "==" "pl"}}<strong>Sprzedawca :</strong>{{else}}{{#compare orders.0.openTextField.language "==" "it"}}<strong>Venditore :</strong>{{else}}{{#compare orders.0.openTextField.language "==" "de"}}<strong>Verkäufer :</strong>{{else}}<strong>Vendeur :</strong>{{/compare}}{{/compare}}{{/compare}} {{orders.0.sellers.0.name}}
                    </p>
                    {{/if}}
                    {{#if orders.0.openTextField.newStatus}}
                    <p style="margin-bottom:6px;">
                      {{! New status label }}
{{#compare orders.0.openTextField.language "==" "pl"}}<strong>Nowy status :</strong>{{else}}{{#compare orders.0.openTextField.language "==" "it"}}<strong>Nuovo stato :</strong>{{else}}{{#compare orders.0.openTextField.language "==" "de"}}<strong>Neuer Status :</strong>{{else}}<strong>Nouveau statut :</strong>{{/compare}}{{/compare}}{{/compare}}
                      {{#compare orders.0.openTextField.newStatus "==" 1}}
{{#compare orders.0.openTextField.language "==" "pl"}}En cours d'autorisation{{else}}{{#compare orders.0.openTextField.language "==" "it"}}In autorizzazione{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Wird autorisiert{{else}}En cours d'autorisation{{/compare}}{{/compare}}{{/compare}}
                      {{else}}{{#compare orders.0.openTextField.newStatus "==" 2}}
{{#compare orders.0.openTextField.language "==" "pl"}}Autoryzowana{{else}}{{#compare orders.0.openTextField.language "==" "it"}}Autorizzato{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Autorisiert{{else}}Autorisé{{/compare}}{{/compare}}{{/compare}}
                      {{else}}{{#compare orders.0.openTextField.newStatus "==" 6}}
{{#compare orders.0.openTextField.language "==" "pl"}}Anulowana{{else}}{{#compare orders.0.openTextField.language "==" "it"}}Annullato{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Storniert{{else}}Annulé{{/compare}}{{/compare}}{{/compare}}
                      {{else}}{{orders.0.openTextField.newStatus}}{{/compare}}{{/compare}}{{/compare}}
                    </p>
                    {{/if}}
                  </td>
                </tr>
              </table>

              <p>
                {{! Account CTA text }}
{{#compare orders.0.openTextField.language "==" "pl"}}Aby uzyskać więcej informacji na temat swojej płatności, zaloguj się na swoje konto CHANEL.{{else}}{{#compare orders.0.openTextField.language "==" "it"}}Per ulteriori informazioni sul suo pagamento, acceda al suo account CHANEL.{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Für weitere Informationen zu Ihrer Zahlung melden Sie sich bitte in Ihrem CHANEL-Konto an.{{else}}Pour plus d'informations sur votre paiement, connectez-vous à votre compte CHANEL.{{/compare}}{{/compare}}{{/compare}}
              </p>

              <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-bottom:28px;">
                <tr>
                  <td>
                    <a href="{{#compare orders.0.openTextField.language "==" "pl"}}https://www.chanel.com/pl/account/{{else}}{{#compare orders.0.openTextField.language "==" "it"}}https://www.chanel.com/it/account/{{else}}{{#compare orders.0.openTextField.language "==" "de"}}https://www.chanel.com/de/account/{{else}}https://www.chanel.com/fr/account/{{/compare}}{{/compare}}{{/compare}}" class="btn-primary" target="_blank">{{! Account CTA button }}
{{#compare orders.0.openTextField.language "==" "pl"}}Moje konto{{else}}{{#compare orders.0.openTextField.language "==" "it"}}Il mio account{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Mein Konto{{else}}Mon compte{{/compare}}{{/compare}}{{/compare}}
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>

        <!-- HELP -->
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" class="help-section">
          <tr><td>&nbsp;</td></tr>
          <tr>
            <td>
              <h2 class="h2-flush">{{! Help heading }}
{{#compare orders.0.openTextField.language "==" "pl"}}Potrzebujesz pomocy?{{else}}{{#compare orders.0.openTextField.language "==" "it"}}Hai bisogno di aiuto?{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Benötigen Sie Hilfe?{{else}}Besoin d'aide ?{{/compare}}{{/compare}}{{/compare}}</h2>
              <p style="margin-bottom:10px;">
                {{! Help text }}
{{#compare orders.0.openTextField.language "==" "pl"}}Więcej informacji znajdziesz w naszym <a href="https://www.chanel.com/pl/faq/" style="color:#1d1d1d;text-decoration:underline;">FAQ</a> lub kontaktując się z naszym <a href="https://www.chanel.com/pl/uslugi-i-pielegnacja/" style="color:#1d1d1d;text-decoration:underline;">Działem obsługi klienta</a>.{{else}}{{#compare orders.0.openTextField.language "==" "it"}}Troverete maggiori informazioni nelle nostre <a href="https://www.chanel.com/it/faq/" style="color:#1d1d1d;text-decoration:underline;">FAQ</a> o contattando il nostro <a href="https://www.chanel.com/it/servizio-clienti/" style="color:#1d1d1d;text-decoration:underline;">Servizio clienti</a>.{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Weitere Informationen finden Sie in unseren <a href="https://www.chanel.com/de/faq/" style="color:#1d1d1d;text-decoration:underline;">FAQ</a> oder wenden Sie sich an unseren <a href="https://www.chanel.com/de/kundenservice/" style="color:#1d1d1d;text-decoration:underline;">Kundendienst</a>.{{else}}Vous trouverez plus d'informations dans notre <a href="https://www.chanel.com/fr/faq/" style="color:#1d1d1d;text-decoration:underline;">FAQ</a> ou en contactant notre <a href="https://www.chanel.com/fr/conseils-services/" style="color:#1d1d1d;text-decoration:underline;">Service client</a>.{{/compare}}{{/compare}}{{/compare}}
              </p>
              <p class="p-muted">
                {{! Privacy text }}
{{#compare orders.0.openTextField.language "==" "pl"}}Aby uzyskać informacje na temat gromadzenia i przetwarzania Twoich danych osobowych przez CHANEL, zapoznaj się z naszą
                <a href="https://www.chanel.com/pl/polityka-prywatnosci/" style="color:#9b9b9b;text-decoration:underline;">Polityką prywatności</a>.{{else}}{{#compare orders.0.openTextField.language "==" "it"}}Per informazioni sulla raccolta e il trattamento dei dati personali da parte di CHANEL, consultare la nostra
                <a href="https://www.chanel.com/it/informativa-sulla-privacy/" style="color:#9b9b9b;text-decoration:underline;">Informativa sulla privacy</a>.{{else}}{{#compare orders.0.openTextField.language "==" "de"}}Informationen zur Erhebung und Verarbeitung Ihrer personenbezogenen Daten durch CHANEL finden Sie in unserer
                <a href="https://www.chanel.com/de/datenschutzbestimmungen/" style="color:#9b9b9b;text-decoration:underline;">Datenschutzrichtlinie</a>.{{else}}Pour toute information concernant la collecte et le traitement de vos données personnelles par CHANEL, consultez notre
                <a href="https://www.chanel.com/fr/politique-de-confidentialite/" style="color:#9b9b9b;text-decoration:underline;">Politique de confidentialité</a>.{{/compare}}{{/compare}}{{/compare}}
              </p>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>

