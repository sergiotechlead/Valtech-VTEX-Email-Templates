  </noscript>
  <![endif]-->
  <style type="text/css">

  /* ============================================================
     CHANEL Email Templates — Design System
     Edit ONLY this <style> block to update all visual properties.
     ============================================================

     COLOR TOKENS
     Brand Black   : #000000   (buttons, borders, headings)
     Text Dark     : #1d1d1d   (greeting h1, body links)
     Text Body     : #333333   (paragraphs, table cells)
     Text Muted    : #9b9b9b   (footer, legal notices)
     Background    : #f9f9f9   (page bg, info panels)
     White         : #ffffff   (email body)
     Border Light  : #eeeeee   (row dividers)
     Border Dark   : #333333   (footer divider)

     TYPOGRAPHY
     Font stack    : Arial, Helvetica, sans-serif
     H1 size       : 22px  (mobile: 18px)
     H2 size       : 12px  uppercase, letter-spacing 0.7px
     Body size     : 14px  line-height 23px
     Small / legal : 11px  line-height 20px

     SPACING
     Section gap   : 28px
     Info panel    : 16px 20px
     Content pad   : 0 40px 40px
  */

  /* --- Reset ------------------------------------------------- */
  body,table,td,p,a,li { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
  body,td,th,input,textarea,select,p,span { font-family:Arial,ArialMT,Helvetica,sans-serif; }
  table,td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
  img { -ms-interpolation-mode:bicubic; border:0; outline:none; text-decoration:none; }

  /* --- Layout ------------------------------------------------ */
  body             { margin:0; padding:0; background-color:#f9f9f9; }
  .email-wrapper   { width:100%; background-color:#f9f9f9; }
  .email-container { max-width:640px; margin:0 auto; background-color:#ffffff; }

  /* --- Typography -------------------------------------------- */
  h1 {
    font-family: Arial, Helvetica, sans-serif;
    font-size:   22px;
    font-weight: 400;
    color:       #1d1d1d;
    margin:      0 0 16px;
    line-height: 1.4;
  }
  h2 {
    font-family:    Arial, Helvetica, sans-serif;
    font-size:      12px;
    font-weight:    700;
    color:          #000000;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin:         28px 0 12px;
    line-height:    1.4;
  }
  p {
    font-family: Arial, Helvetica, sans-serif;
    font-size:   14px;
    color:       #333333;
    line-height: 23px;
    margin:      0 0 14px;
  }
  a      { color:#1d1d1d; text-decoration:underline; }
  strong { color:#000000; }

  /* h2 variant — flush top (used inside the help section) */
  .h2-flush { margin-top:0; }

  /* Small muted text — privacy & legal notices */
  .p-muted   { font-size:11px; color:#9b9b9b; line-height:20px; margin:0; }
  .p-muted a { color:#9b9b9b; }

  /* --- Product table ----------------------------------------- */
  .product-table              { width:100%; border-collapse:collapse; }
  .product-table th           { font-family:Arial,Helvetica,sans-serif; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.7px; color:#000000; padding:8px 0; border-bottom:2px solid #000000; text-align:left; }
  .product-table th.col-qty   { padding:8px 6px; text-align:center; }
  .product-table th.col-price { text-align:right; }
  .product-table td           { font-family:Arial,Helvetica,sans-serif; font-size:14px; color:#333333; padding:12px 0; border-bottom:1px solid #eeeeee; vertical-align:top; }
  .product-table td.col-qty   { padding:12px 6px; text-align:center; }
  .product-table td.col-price { text-align:right; white-space:nowrap; }

  /* --- Totals table ------------------------------------------ */
  .totals-table              { width:100%; border-collapse:collapse; margin-top:16px; }
  .totals-table td           { font-family:Arial,Helvetica,sans-serif; font-size:14px; color:#333333; padding:5px 0; }
  .totals-table td.col-price { text-align:right; white-space:nowrap; }
  .totals-table .total-row td { font-weight:700; color:#000000; border-top:1px solid #000000; padding-top:10px; }

  /* --- Info panels (shipping address, payment, delivery) ----- */
  .info-box    { background-color:#f9f9f9; margin-bottom:28px; }
  .info-box td { padding:16px 20px; }
  .info-box p  { font-family:Arial,Helvetica,sans-serif; font-size:14px; color:#333333; line-height:22px; margin:0; }

  /* --- CTA button -------------------------------------------- */
  .btn-primary { display:inline-block; background-color:#000000; color:#ffffff; font-family:Arial,Helvetica,sans-serif; font-size:14px; font-weight:700; text-transform:uppercase; letter-spacing:1px; text-decoration:none; padding:14px 32px; }

  /* --- Verification code box --------------------------------- */
  .code-box    { background-color:#f9f9f9; text-align:center; margin:24px 0; }
  .code-box td { padding:16px 20px; text-align:center; }
  .code-box p  { font-family:Arial,Helvetica,sans-serif; font-size:40px; letter-spacing:20px; color:#000000; margin:0; padding-left:20px; line-height:1.4; }

  /* --- Help section ------------------------------------------ */
  .help-section    { margin-top:28px; border-top:1px solid #eeeeee; }
  .help-section td { height:28px; }

  /* --- Footer ------------------------------------------------ */
  .footer-nav-list    { font-size:14px; line-height:22px; padding:0; margin:0; color:#9b9b9b; list-style-type:none; }
  .footer-nav-list li { margin-bottom:9px; }
  .footer-nav-list a  { text-decoration:none; color:#9b9b9b; }
  .footer-legal       { color:#9b9b9b; font-size:12px; text-align:center; line-height:16px; }
  .footer-legal p     { font-size:12px; color:#9b9b9b; margin-bottom:3px; }
  .footer-legal a     { color:#9b9b9b; }

  /* --- Responsive ------------------------------------------- */
  @media only screen and (max-width:640px) {
    .email-container { width:100%!important; }
    .footer-col      { width:100%!important; display:block!important; padding:0 0 20px 0!important; }
    .content-padding { padding:20px!important; }
    h1               { font-size:18px!important; }
  }

  </style>
</head>
<body style="margin:0;padding:0;background-color:#f9f9f9;">
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="width:100%;background-color:#f9f9f9;" class="email-wrapper">
    <tr>
      <td>

  <!-- TOP BAR -->
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#000000;max-width:640px;margin:0 auto;">
    <tr><td style="height:7px;font-size:7px;line-height:7px;">&nbsp;</td></tr>
  </table>
  <!-- LOGO HEADER -->
  <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width:640px;margin:0 auto;background-color:#ffffff;">
    <tr>
      <td align="center" style="padding:36px 40px 30px;background-color:#ffffff;">
        <a href="https://www.chanel.com/fr/" style="text-decoration:none;border:0;display:inline-block;" target="_blank" aria-label="Page d'accueil CHANEL">
          <svg xmlns="http://www.w3.org/2000/svg" width="175" height="28" viewBox="0 0 175 28" role="img" aria-label="CHANEL"><title>CHANEL</title><path fill="#000000" fill-rule="evenodd" d="m20.655 17.726 4.565 2.615c-2.282 4.197-6.737 6.922-11.781 6.922C6.075 27.263 0 21.629 0 13.713S6.075.163 13.439.163c5.044 0 9.5 2.725 11.781 6.923L20.655 9.7c-1.326-2.725-4.013-4.381-7.216-4.381-4.603 0-8.1 3.423-8.1 8.394s3.497 8.395 8.1 8.395c3.203 0 5.89-1.657 7.216-4.382m29.05 8.874V15.554H36.818V26.6h-5.154V.826h5.154V10.4h12.887V.826h5.155V26.6zm29.898-10.678L74.926 5.061 70.25 15.922zM89.838 26.6h-5.634l-2.54-5.892H68.188l-2.54 5.892h-5.634L71.428.826h6.996zm23.748 0L99.778 6.313V26.6h-4.786V.826h6.812l11.598 17.084V.826h4.787V26.6zm14.543 0V.826h18.41v4.787h-13.624v5.523h11.782v4.786h-11.782v5.892h14.36V26.6zm27.431 0V.826h5.154v20.62h13.622V26.6z"/></svg>
        </a>
      </td>
    </tr>
  </table>
        <!-- MAIN CONTENT -->
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width:640px;margin:0 auto;background-color:#ffffff;">
          <tr>
            <td style="padding:0 40px 40px;" class="content-padding">

              <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top:36px;">
                <tr>
                  <td>
                    {{#if clientProfileData.firstName}}
                    {{! Greeting with firstName }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}<h1>Hello {{clientProfileData.firstName}},</h1>{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}<h1>Dzień dobry {{clientProfileData.firstName}},</h1>{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<h1>Ciao {{clientProfileData.firstName}},</h1>{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<h1>Guten Tag {{clientProfileData.firstName}},</h1>{{else}}<h1>Bonjour {{clientProfileData.firstName}},</h1>{{/compare}}{{/compare}}{{/compare}}{{/compare}}
                    {{else}}
                    {{! Default greeting }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}<h1>Dear Customer,</h1>{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}<h1>Drogi Kliencie,</h1>{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<h1>Gentile cliente,</h1>{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<h1>Sehr geehrter Kunde,</h1>{{else}}<h1>Cher client,</h1>{{/compare}}{{/compare}}{{/compare}}{{/compare}}
                    {{/if}}
                    <p>
                      {{! Body paragraph payment approved }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Your payment has been accepted. Your order is now being prepared.{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Twoja płatność została zaakceptowana. Twoje zamówienie jest teraz przygotowywane.{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Il suo pagamento è stato accettato. Il suo ordine è in fase di preparazione.{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Ihre Zahlung wurde akzeptiert. Ihre Bestellung wird derzeit vorbereitet.{{else}}Votre paiement a été accepté. Votre commande est maintenant en cours de préparation.{{/compare}}{{/compare}}{{/compare}}{{/compare}}
                    </p>
                    {{#if orderId}}
                    <p style="margin-bottom:28px;">
                      {{! Order number label }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}<strong>Order No.:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}<strong>Nr zamówienia:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<strong>N° ordine:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<strong>Bestellnummer:</strong>{{else}}<strong>N° de commande :</strong>{{/compare}}{{/compare}}{{/compare}}{{/compare}} {{orderId}}
                    </p>
                    {{/if}}
                  </td>
                </tr>
              </table>
              
        {{#if items}}
        <h2>{{! Section ordered items }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Ordered Items{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Zamówione artykuły{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Articoli ordinati{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Bestellte Artikel{{else}}Articles commandés{{/compare}}{{/compare}}{{/compare}}{{/compare}}</h2>
        <table role="presentation" class="product-table" width="100%" border="0" cellspacing="0" cellpadding="0" style="width:100%;border-collapse:collapse;">
          <thead>
            <tr>
              <th>{{! TH item }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Item{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Artykuł{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Articolo{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Artikel{{else}}Article{{/compare}}{{/compare}}{{/compare}}{{/compare}}</th>
              <th class="col-qty">{{! TH qty }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Qty{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Ilość{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Qtà{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Menge{{else}}Qté{{/compare}}{{/compare}}{{/compare}}{{/compare}}</th>
              <th class="col-price">{{! TH price }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Price{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Cena{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Prezzo{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Preis{{else}}Prix{{/compare}}{{/compare}}{{/compare}}{{/compare}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each items}}
            <tr>
              <td>{{name}}</td>
              <td class="col-qty">{{quantity}}</td>
              <td class="col-price">{{formatCurrency sellingPrice}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{/if}}
              
        {{#if totals}}
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" class="totals-table">
          {{#each totals}}
          {{#if value}}
          <tr>
            <td>{{name}}</td>
            <td class="col-price">{{formatCurrency value}}</td>
          </tr>
          {{/if}}
          {{/each}}
        </table>
        {{/if}}
              
        {{#if shippingData.address}}
        <h2>{{! Section shipping address }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Delivery Address{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Adres dostawy{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Indirizzo di consegna{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Lieferadresse{{else}}Adresse de livraison{{/compare}}{{/compare}}{{/compare}}{{/compare}}</h2>
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" class="info-box">
          <tr>
            <td>
              {{#if shippingData.address.receiverName}}
              <p><strong>{{shippingData.address.receiverName}}</strong></p>
              {{/if}}
              <p style="margin-top:4px;">
                {{shippingData.address.street}}{{#if shippingData.address.number}}, {{shippingData.address.number}}{{/if}}<br>
                {{#if shippingData.address.complement}}{{shippingData.address.complement}}<br>{{/if}}
                {{shippingData.address.postalCode}} {{shippingData.address.city}}<br>
                {{shippingData.address.country}}
              </p>
            </td>
          </tr>
        </table>
        {{/if}}
              
        {{#if shippingData.logisticsInfo}}
        <h2>{{! Section estimated delivery }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Estimated Delivery Time{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Szacowany czas dostawy{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Tempo di consegna stimato{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Geschätzte Lieferzeit{{else}}Délai de livraison estimé{{/compare}}{{/compare}}{{/compare}}{{/compare}}</h2>
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" class="info-box">
          <tr>
            <td>
              {{#each shippingData.logisticsInfo}}
              {{#each slas}}
              {{#compare ../selectedSla "==" id}}
              <p style="margin-bottom:6px;"><strong>{{name}}</strong></p>
              {{#if deliveryWindow}}
              <p>
                {{! Delivery window }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Scheduled delivery on {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} between {{formatDate deliveryWindow.startDateUtc "HH:mm"}} and {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Planowana dostawa {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} między {{formatDate deliveryWindow.startDateUtc "HH:mm"}} a {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Consegna prevista il {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} tra le {{formatDate deliveryWindow.startDateUtc "HH:mm"}} e le {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Geplante Lieferung am {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} zwischen {{formatDate deliveryWindow.startDateUtc "HH:mm"}} und {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{else}}Livraison prévue le {{formatDate deliveryWindow.startDateUtc "DD/MM/YYYY"}} entre {{formatDate deliveryWindow.startDateUtc "HH:mm"}} et {{formatDate deliveryWindow.endDateUtc "HH:mm"}}{{/compare}}{{/compare}}{{/compare}}{{/compare}}
              </p>
              {{else}}
              <p>
                {{! Delivery estimate }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Estimated delivery: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} working day(s){{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Szacowany termin dostawy: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} dzień(dni) roboczy(ch){{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Consegna stimata: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} giorno(i) lavorativo(i){{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Geschätzte Lieferung: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} Werktag(e){{else}}Livraison estimée&nbsp;: {{replace (replace shippingEstimate 'bd' '') 'd' ''}} jour(s) ouvré(s){{/compare}}{{/compare}}{{/compare}}{{/compare}}
              </p>
              {{/if}}
              {{/compare}}
              {{/each}}
              {{/each}}
            </td>
          </tr>
        </table>
        {{/if}}
              {{#if paymentData.transactions}}
              <h2>{{! Section payment info }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Payment Information{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Informacje o płatności{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Informazioni sul pagamento{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Zahlungsinformationen{{else}}Informations de paiement{{/compare}}{{/compare}}{{/compare}}{{/compare}}</h2>
              <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" class="info-box">
                <tr>
                  <td>
                    {{#each paymentData.transactions}}
                    {{#each payments}}
                    <p style="margin-bottom:4px;">
                      {{! Payment method label }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}<strong>Payment Method:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}<strong>Metoda płatności:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<strong>Metodo di pagamento:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<strong>Zahlungsmethode:</strong>{{else}}<strong>Mode de paiement :</strong>{{/compare}}{{/compare}}{{/compare}}{{/compare}} {{paymentSystemName}}
                    </p>
                    {{#if installments}}
                    <p>
                      {{! Installments label }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}<strong>In:</strong> {{installments}} installment(s){{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}<strong>W:</strong> {{installments}} racie(ach){{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<strong>In:</strong> {{installments}} rata(e){{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<strong>In:</strong> {{installments}} Rate(n){{else}}<strong>En :</strong> {{installments}} fois{{/compare}}{{/compare}}{{/compare}}{{/compare}}
                    </p>
                    {{/if}}
                    {{/each}}
                    {{/each}}
                  </td>
                </tr>
              </table>
              {{/if}}

        <!-- HELP -->
        <table role="presentation" width="100%" border="0" cellspacing="0" cellpadding="0" class="help-section">
          <tr><td>&nbsp;</td></tr>
          <tr>
            <td>
              <h2 class="h2-flush">{{! Help heading }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}Need help?{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Potrzebujesz pomocy?{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Hai bisogno di aiuto?{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Benötigen Sie Hilfe?{{else}}Besoin d'aide ?{{/compare}}{{/compare}}{{/compare}}{{/compare}}</h2>
              <p style="margin-bottom:10px;">
                {{! Help text }}
{{#compare clientPreferencesData.locale "==" "en-GB"}}You will find more information in our <a href="https://www.chanel.com/en/faq/" style="color:#1d1d1d;text-decoration:underline;">FAQ</a> or by contacting our <a href="https://www.chanel.com/en/customer-service/" style="color:#1d1d1d;text-decoration:underline;">Customer Service</a>.{{else}}{{#compare clientPreferencesData.locale "==" "pl-PL"}}Więcej informacji znajdziesz w naszym <a href="https://www.chanel.com/pl/faq/" style="color:#1d1d1d;text-decoration:underline;">FAQ</a> lub kontaktując się z naszym <a href="https://www.chanel.com/pl/obsluga-klienta/" style="color:#1d1d1d;text-decoration:underline;">Działem obsługi klienta</a>.{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Troverete maggiori informazioni nelle nostre <a href="https://www.chanel.com/it/faq/" style="color:#1d1d1d;text-decoration:underline;">FAQ</a> o contattando il nostro <a href="https://www.chanel.com/it/servizio-clienti/" style="color:#1d1d1d;text-decoration:underline;">Servizio clienti</a>.{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Weitere Informationen finden Sie in unseren <a href="https://www.chanel.com/de/faq/" style="color:#1d1d1d;text-decoration:underline;">FAQ</a> oder wenden Sie sich an unseren <a href="https://www.chanel.com/de/kundenservice/" style="color:#1d1d1d;text-decoration:underline;">Kundendienst</a>.{{else}}Vous trouverez plus d'informations dans notre <a href="https://www.chanel.com/fr/faq/" style="color:#1d1d1d;text-decoration:underline;">FAQ</a> ou en contactant notre <a href="https://www.chanel.com/fr/conseils-services/" style="color:#1d1d1d;text-decoration:underline;">Service client</a>.{{/compare}}{{/compare}}{{/compare}}{{/compare}}
              </p>
              <p class="p-muted">
                {{! Privacy text }}
