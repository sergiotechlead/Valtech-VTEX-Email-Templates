{{#compare clientPreferencesData.locale "==" "pl-PL"}}Artykuł{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Articolo{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Artikel{{else}}Article{{/compare}}{{/compare}}{{/compare}}</th>
