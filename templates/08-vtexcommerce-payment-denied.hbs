                    {{#if clientProfileData.lastName}}
{{#compare clientPreferencesData.locale "==" "pl-PL"}}<p style="margin-bottom:30px;">Szanowny/a Panie/Pani {{clientProfileData.lastName}},</p>{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<p style="margin-bottom:30px;">Gentile Sig./Sig.ra {{clientProfileData.lastName}},</p>{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<p style="margin-bottom:30px;">Sehr geehrte/r Herr/Frau {{clientProfileData.lastName}},</p>{{else}}<p style="margin-bottom:30px;">Cher/Chère M. {{clientProfileData.lastName}},</p>{{/compare}}{{/compare}}{{/compare}}
                    {{else}}{{#if clientProfileData.firstName}}
{{#compare clientPreferencesData.locale "==" "pl-PL"}}<p style="margin-bottom:30px;">Szanowny/a Panie/Pani {{clientProfileData.firstName}},</p>{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<p style="margin-bottom:30px;">Gentile Sig./Sig.ra {{clientProfileData.firstName}},</p>{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<p style="margin-bottom:30px;">Sehr geehrte/r Herr/Frau {{clientProfileData.firstName}},</p>{{else}}<p style="margin-bottom:30px;">Cher/Chère {{clientProfileData.firstName}},</p>{{/compare}}{{/compare}}{{/compare}}
                    {{else}}
{{#compare clientPreferencesData.locale "==" "pl-PL"}}<p style="margin-bottom:30px;">Szanowny/a Kliencie,</p>{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<p style="margin-bottom:30px;">Gentile Cliente,</p>{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<p style="margin-bottom:30px;">Sehr geehrte/r Kunde/Kundin,</p>{{else}}<p style="margin-bottom:30px;">Cher Client,</p>{{/compare}}{{/compare}}{{/compare}}
                    {{/if}}{{/if}}
                    <p>
                      {{! Body paragraph payment denied }}
{{#compare clientPreferencesData.locale "==" "pl-PL"}}Z przykrością informujemy, że Twoja płatność nie mogła zostać przetworzona. Proszę sprawdzić dane płatności i spróbować ponownie.{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Siamo spiacenti di informarla che il suo pagamento non ha potuto essere elaborato. Si prega di verificare le informazioni di pagamento e riprovare.{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Wir bedauern, Ihnen mitteilen zu müssen, dass Ihre Zahlung nicht verarbeitet werden konnte. Bitte überprüfen Sie Ihre Zahlungsinformationen und versuchen Sie es erneut.{{else}}Nous sommes désolés de vous informer que votre paiement n'a pas pu être traité. Veuillez vérifier vos informations de paiement et réessayer.{{/compare}}{{/compare}}{{/compare}}
                    </p>
                    {{#if orderId}}
                    <p>
                      {{! Order number label }}
{{#compare clientPreferencesData.locale "==" "pl-PL"}}<strong>Nr zamówienia:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<strong>N° ordine:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<strong>Bestellnummer:</strong>{{else}}<strong>N° de commande :</strong>{{/compare}}{{/compare}}{{/compare}} {{orderId}}
                    </p>
                    {{/if}}
                    {{#if cancellationReason}}
                    <p>
                      {{! Reason label }}
{{#compare clientPreferencesData.locale "==" "pl-PL"}}<strong>Powód:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}<strong>Motivo:</strong>{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}<strong>Grund:</strong>{{else}}<strong>Motif :</strong>{{/compare}}{{/compare}}{{/compare}} {{cancellationReason}}
