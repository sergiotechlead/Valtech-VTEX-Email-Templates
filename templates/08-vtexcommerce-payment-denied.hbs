{{#compare clientPreferencesData.locale "==" "pl-PL"}}Zamówione artykuły{{else}}{{#compare clientPreferencesData.locale "==" "it-IT"}}Articoli ordinati{{else}}{{#compare clientPreferencesData.locale "==" "de-DE"}}Bestellte Artikel{{else}}Articles commandés{{/compare}}{{/compare}}{{/compare}}</h2>
