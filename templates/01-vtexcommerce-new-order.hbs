<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional //EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:v="urn:schemas-microsoft-com:vml">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="x-apple-disable-message-reformatting"/>
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no"/>
  <title>{{_accountInfo.TradingName}}</title>
  <!--[if gte mso 9]>
  <xml>
    <o:OfficeDocumentSettings>
      <o:AllowPNG/>
      <o:PixelsPerInch>96</o:PixelsPerInch>
    </o:OfficeDocumentSettings>
  </xml>
  <![endif]-->
  <style type="text/css">
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }
    table { border-collapse: collapse !important; }
    body { margin: 0 !important; padding: 0 !important; background-color: #f4f4f4; }
    a[x-apple-data-detectors] {
      color: inherit !important; text-decoration: none !important;
      font-size: inherit !important; font-family: inherit !important;
      font-weight: inherit !important; line-height: inherit !important;
    }
    u + #body a { color: inherit; text-decoration: none; font-size: inherit; font-family: inherit; font-weight: inherit; line-height: inherit; }
    #MessageViewBody a { color: inherit; text-decoration: none; font-size: inherit; font-family: inherit; font-weight: inherit; line-height: inherit; }
    @media only screen and (max-width: 640px) {
      .email-container { width: 100% !important; }
      .mobile-padding { padding-left: 24px !important; padding-right: 24px !important; }
      .fluid { max-width: 100% !important; height: auto !important; }
      .stack-column { display: block !important; width: 100% !important; float: none !important; }
      h1 { font-size: 26px !important; line-height: 34px !important; }
    }
  </style>
</head>
<body id="body" style="margin: 0; padding: 0; background-color: #f4f4f4;">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #f4f4f4;">
  <tr>
    <td align="center" valign="top" style="padding: 24px 0;">
      <table role="presentation" class="email-container" cellpadding="0" cellspacing="0" border="0" width="640" style="max-width: 640px; width: 100%; background-color: #ffffff; border-top: 7px solid #000000;">

        <!-- HEADER -->
        <tr>
          <td align="center" class="mobile-padding" style="padding: 32px 40px 24px; border-bottom: 1px solid #eeeeee;">
            <a href="https://{{_accountInfo.HostName}}" style="text-decoration: none; display: block;">
              <img src="https://licensemanager.vtex.com.br/api/site/pub/accounts/{{_accountInfo.Id}}/logos/show" width="172" alt="{{_accountInfo.TradingName}}" border="0" style="display: block; margin: 0 auto; max-width: 172px; height: auto;"/>
            </a>
          </td>
        </tr>

        <!-- TITLE -->
        <tr>
          <td align="center" class="mobile-padding" style="padding: 40px 40px 24px; border-bottom: 1px solid #eeeeee;">
            {{#eq clientPreferencesData.locale "fr-CA"}}
            <h1 style="font-family: Arial, Helvetica, sans-serif; font-size: 32px; line-height: 40px; font-weight: 700; color: #000000; margin: 0 0 16px;">Merci pour votre commande.</h1>
            {{else}}
            <h1 style="font-family: Arial, Helvetica, sans-serif; font-size: 32px; line-height: 40px; font-weight: 700; color: #000000; margin: 0 0 16px;">Thank you for your order.</h1>
            {{/eq}}
          </td>
        </tr>

        <!-- GREETING & MESSAGE -->
        <tr>
          <td class="mobile-padding" style="padding: 32px 40px;">
            <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 12px;">
              {{#if orders}}
                {{#if orders.0.clientProfileData.firstName}}
                  {{#compare orders.0.clientProfileData.firstName '!=' 'isAnonymous'}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Bonjour {{orders.0.clientProfileData.firstName}},{{else}}Hi {{orders.0.clientProfileData.firstName}},{{/eq}}
                  {{/compare}}
                {{/if}}
              {{else}}
                {{#if clientProfileData.firstName}}
                  {{#compare clientProfileData.firstName '!=' 'isAnonymous'}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Bonjour {{clientProfileData.firstName}},{{else}}Hi {{clientProfileData.firstName}},{{/eq}}
                  {{/compare}}
                {{/if}}
              {{/if}}
            </p>
            <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 12px;">
              {{#eq clientPreferencesData.locale "fr-CA"}}
                Nous attendons l'approbation du paiement pour traiter votre commande.
              {{else}}
                We are awaiting payment approval to process your order.
              {{/eq}}
            </p>
            <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 12px;">
              <a href="{{ordersUrl}}" style="color: #000000; text-decoration: underline;">
                {{#eq clientPreferencesData.locale "fr-CA"}}Suivre cette commande sur notre site{{else}}Track this order on our site{{/eq}}
              </a>
            </p>

            {{#each orders.0.paymentData.transactions}}
              {{#each payments}}
                {{#eq paymentSystemName 'Boleto Bancário'}}
                  <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 12px;">
                    {{#eq clientPreferencesData.locale "fr-CA"}}N'oubliez pas d'effectuer le paiement du boleto bancário si ce n'est pas encore fait.{{else}}Don't forget to pay your boleto bancário if you haven't done so already.{{/eq}}
                  </p>
                  <p style="margin: 0 0 12px;">
                    <a href="{{replace url '{Installment}' installments}}" style="display: inline-block; background-color: #000000; color: #ffffff; font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: 700; text-decoration: none; padding: 14px 28px; letter-spacing: 0.5px;">
                      {{#eq clientPreferencesData.locale "fr-CA"}}Ouvrir le boleto{{else}}Open Boleto{{/eq}}
                    </a>
                  </p>
                {{/eq}}
              {{/each}}
            {{/each}}
          </td>
        </tr>

        <!-- DIVIDER -->
        <tr><td style="border-top: 1px solid #eeeeee; height: 1px; line-height: 1px; font-size: 1px;">&nbsp;</td></tr>

        <!-- PACKAGE SUMMARY -->
        <tr>
          <td class="mobile-padding" style="padding: 32px 40px;">
            <h3 style="font-family: Arial, Helvetica, sans-serif; font-size: 11px; line-height: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: 1pt; color: #999999; margin: 0 0 16px;">
              {{#eq clientPreferencesData.locale "fr-CA"}}Résumé de vos colis{{else}}Package Summary{{/eq}}
            </h3>
            {{#each orders}}
              {{#richShippingData shippingData}}
                {{#group logisticsInfo by="packageId"}}
                  {{#each items}}
                    {{#compare @index '==' 0}}
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom: 12px;">
                        <tr>
                          <td style="background-color: #f7f7f7; padding: 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
                            {{#eq selectedDeliveryChannel "pickup-in-point"}}
                              <strong style="text-transform: uppercase; font-size: 11px; letter-spacing: 1pt; color: #999999;">
                                {{#eq ../../clientPreferencesData.locale "fr-CA"}}Retrait{{else}}Pickup{{/eq}}
                              </strong>
                            {{else}}
                              <strong style="text-transform: uppercase; font-size: 11px; letter-spacing: 1pt; color: #999999;">
                                {{#eq ../../clientPreferencesData.locale "fr-CA"}}Livraison{{else}}Delivery{{/eq}}
                              </strong>
                            {{/eq}}

                            {{#eq ../items.length 1}}
                              {{#each ../../../items}}
                                {{#compare id '==' ../../items.0.itemId}}
                                  <p style="margin: 4px 0 0; font-weight: 700; color: #000000;">{{name}}</p>
                                {{/compare}}
                              {{/each}}
                            {{else}}
                              <p style="margin: 4px 0 0; color: #000000;">{{../items.length}}
                                {{#eq ../../clientPreferencesData.locale "fr-CA"}}articles{{else}}items{{/eq}}
                              </p>
                            {{/eq}}

                            {{#if deliveryWindow}}
                              <p style="margin: 8px 0 0; font-size: 13px; color: #777777;">
                                {{formatDate deliveryWindow.startDateUtc}} — {{formatTime deliveryWindow.startDateUtc}} {{#eq ../../clientPreferencesData.locale "fr-CA"}}à{{else}}to{{/eq}} {{formatTime deliveryWindow.endDateUtc}}
                              </p>
                            {{else}}
                              {{#if shippingEstimateDate}}
                                <p style="margin: 8px 0 0; font-size: 13px; color: #777777;">
                                  {{#eq deliveryChannel "pickup-in-point"}}
                                    {{#eq ../../clientPreferencesData.locale "fr-CA"}}À partir de{{else}}After{{/eq}}
                                  {{else}}
                                    {{#eq ../../clientPreferencesData.locale "fr-CA"}}Jusqu'au{{else}}By{{/eq}}
                                  {{/eq}}
                                  {{formatDate shippingEstimateDate}}
                                </p>
                              {{else}}
                                {{#eq shippingEstimateDays "0"}}
                                  <p style="margin: 8px 0 0; font-size: 13px; color: #777777;">
                                    {{#eq ../../clientPreferencesData.locale "fr-CA"}}Aujourd'hui{{else}}Today{{/eq}}
                                  </p>
                                {{else}}
                                  <p style="margin: 8px 0 0; font-size: 13px; color: #777777;">
                                    {{#eq ../../clientPreferencesData.locale "fr-CA"}}En{{else}}In up to{{/eq}}
                                    {{#compare shippingEstimateDays ">" "1"}}
                                      {{#eq shippingEstimateDaysType "bd"}}{{shippingEstimateDays}} {{#eq ../../clientPreferencesData.locale "fr-CA"}}jours ouvrables{{else}}business days{{/eq}}{{/eq}}
                                      {{#eq shippingEstimateDaysType "d"}}{{shippingEstimateDays}} {{#eq ../../clientPreferencesData.locale "fr-CA"}}jours{{else}}days{{/eq}}{{/eq}}
                                      {{#eq shippingEstimateDaysType "h"}}{{shippingEstimateDays}} {{#eq ../../clientPreferencesData.locale "fr-CA"}}heures{{else}}hours{{/eq}}{{/eq}}
                                    {{else}}
                                      {{#eq shippingEstimateDaysType "bd"}}{{shippingEstimateDays}} {{#eq ../../clientPreferencesData.locale "fr-CA"}}jour ouvrable{{else}}business day{{/eq}}{{/eq}}
                                      {{#eq shippingEstimateDaysType "d"}}{{shippingEstimateDays}} {{#eq ../../clientPreferencesData.locale "fr-CA"}}jour{{else}}day{{/eq}}{{/eq}}
                                      {{#eq shippingEstimateDaysType "h"}}{{shippingEstimateDays}} {{#eq ../../clientPreferencesData.locale "fr-CA"}}heure{{else}}hour{{/eq}}{{/eq}}
                                    {{/compare}}
                                  </p>
                                {{/eq}}
                              {{/if}}
                            {{/if}}

                            <p style="margin: 8px 0 0; font-size: 13px; color: #777777;">
                              {{#eq selectedDeliveryChannel "pickup-in-point"}}
                                {{#each slas}}
                                  {{#compare ../selectedSla '==' id}}{{pickupStoreInfo.friendlyName}}{{/compare}}
                                {{/each}}
                              {{else}}
                                {{#if ../../../giftRegistryData}}
                                  {{../../../giftRegistryData.description}}
                                {{else}}
                                  {{#each ../../availableAddresses}}
                                    {{#eq ../addressId addressId}}{{street}}, {{number}}{{/eq}}
                                  {{/each}}
                                {{/if}}
                              {{/eq}}
                            </p>
                          </td>
                        </tr>
                      </table>
                    {{/compare}}
                  {{/each}}
                {{/group}}
              {{/richShippingData}}
            {{/each}}
          </td>
        </tr>

        <!-- DIVIDER -->
        <tr><td style="border-top: 1px solid #eeeeee; height: 1px; line-height: 1px; font-size: 1px;">&nbsp;</td></tr>

        <!-- PAYMENT (non-split orders) -->
        {{#compare split "!=" true}}
        <tr>
          <td class="mobile-padding" style="padding: 32px 40px;">
            <h3 style="font-family: Arial, Helvetica, sans-serif; font-size: 11px; line-height: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: 1pt; color: #999999; margin: 0 0 16px;">
              {{#eq clientPreferencesData.locale "fr-CA"}}Paiement{{else}}Payment{{/eq}}
            </h3>
            {{#each orders.0.paymentData.transactions}}
              {{#compare payments.length "==" 1}}
                {{#each payments}}
                  <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 4px;">
                    {{paymentSystemName}}{{#if lastDigits}} ···{{lastDigits}}{{/if}} —
                    {{storePreferencesData.currencySymbol}} {{formatCurrency value}}
                    {{#eq installments 1}}
                      ({{#eq ../../clientPreferencesData.locale "fr-CA"}}paiement unique{{else}}in full{{/eq}})
                    {{else}}
                      ({{installments}}x)
                    {{/eq}}
                  </p>
                {{/each}}
              {{/compare}}
              {{#compare payments.length "!=" 1}}
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                  {{#each payments}}
                  <tr>
                    <td style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; padding: 6px 0; border-bottom: 1px solid #eeeeee;">
                      {{paymentSystemName}}{{#if lastDigits}} ···{{lastDigits}}{{/if}}
                      {{#eq installments 1}}({{#eq ../../clientPreferencesData.locale "fr-CA"}}paiement unique{{else}}in full{{/eq}}){{else}}({{installments}}x){{/eq}}
                    </td>
                    <td align="right" style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; padding: 6px 0; border-bottom: 1px solid #eeeeee;">
                      {{storePreferencesData.currencySymbol}} {{formatCurrency value}}
                    </td>
                  </tr>
                  {{/each}}
                </table>
              {{/compare}}
            {{/each}}
            <p style="margin: 12px 0 0;">
              <span style="display: inline-block; background-color: #f7f7f7; font-family: Arial, Helvetica, sans-serif; font-size: 12px; color: #777777; padding: 4px 10px;">
                {{#eq clientPreferencesData.locale "fr-CA"}}En attente d'approbation{{else}}Awaiting approval{{/eq}}
              </span>
            </p>
          </td>
        </tr>
        {{/compare}}

        <!-- DIVIDER -->
        <tr><td style="border-top: 1px solid #eeeeee; height: 1px; line-height: 1px; font-size: 1px;">&nbsp;</td></tr>

        <!-- PER-ORDER ITEMS & SUMMARY -->
        {{#each orders}}
        <tr>
          <td class="mobile-padding" style="padding: 32px 40px;">
            <h2 style="font-family: Arial, Helvetica, sans-serif; font-size: 18px; line-height: 26px; font-weight: 400; color: #000000; margin: 0 0 4px;">
              {{#eq ../clientPreferencesData.locale "fr-CA"}}Commande{{else}}Order{{/eq}} <strong>#{{orderId}}</strong>
            </h2>
            <p style="font-family: Arial, Helvetica, sans-serif; font-size: 13px; line-height: 20px; color: #777777; margin: 0 0 20px;">
              {{#eq ../clientPreferencesData.locale "fr-CA"}}Fourni et livré par{{else}}Provided and delivered by{{/eq}} {{sellers.0.name}}
            </p>

            {{#compare split "==" true}}
            <h3 style="font-family: Arial, Helvetica, sans-serif; font-size: 11px; line-height: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: 1pt; color: #999999; margin: 0 0 12px;">
              {{#eq ../clientPreferencesData.locale "fr-CA"}}Paiement{{else}}Payment{{/eq}}
            </h3>
            {{#each paymentData.transactions}}
              {{#compare payments.length "==" 1}}
                {{#each payments}}
                  <p style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; line-height: 22px; color: #333333; margin: 0 0 4px;">
                    {{paymentSystemName}}{{#if lastDigits}} ···{{lastDigits}}{{/if}} — {{storePreferencesData.currencySymbol}} {{formatCurrency value}}
                    {{#eq installments 1}}({{#eq ../../clientPreferencesData.locale "fr-CA"}}paiement unique{{else}}in full{{/eq}}){{else}}({{installments}}x){{/eq}}
                  </p>
                {{/each}}
              {{/compare}}
              {{#compare payments.length "!=" 1}}
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom: 12px;">
                  {{#each payments}}
                  <tr>
                    <td style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; padding: 5px 0; border-bottom: 1px solid #eeeeee;">
                      {{paymentSystemName}}{{#if lastDigits}} ···{{lastDigits}}{{/if}}
                      {{#eq installments 1}}({{#eq ../../clientPreferencesData.locale "fr-CA"}}paiement unique{{else}}in full{{/eq}}){{else}}({{installments}}x){{/eq}}
                    </td>
                    <td align="right" style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; padding: 5px 0; border-bottom: 1px solid #eeeeee;">
                      {{storePreferencesData.currencySymbol}} {{formatCurrency value}}
                    </td>
                  </tr>
                  {{/each}}
                </table>
              {{/compare}}
            {{/each}}
            {{/compare}}

            <!-- ORDER SUMMARY -->
            <h3 style="font-family: Arial, Helvetica, sans-serif; font-size: 11px; line-height: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: 1pt; color: #999999; margin: 20px 0 12px;">
              {{#eq ../clientPreferencesData.locale "fr-CA"}}Résumé{{else}}Summary{{/eq}}
            </h3>
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin-bottom: 20px;">
              {{#each totals}}
                {{#if value}}
                <tr>
                  <td style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; padding: 5px 0; border-bottom: 1px solid #eeeeee;">
                    {{#eq id "Items"}}{{#eq ../../clientPreferencesData.locale "fr-CA"}}Articles{{else}}Items{{/eq}}{{/eq}}
                    {{#eq id "Shipping"}}{{#eq ../../clientPreferencesData.locale "fr-CA"}}Livraison{{else}}Shipping{{/eq}}{{/eq}}
                    {{#eq id "Discounts"}}{{#eq ../../clientPreferencesData.locale "fr-CA"}}Remises{{else}}Discounts{{/eq}}{{/eq}}
                    {{#eq id "Tax"}}{{#eq ../../clientPreferencesData.locale "fr-CA"}}Taxes{{else}}Taxes{{/eq}}{{/eq}}
                  </td>
                  <td align="right" style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; padding: 5px 0; border-bottom: 1px solid #eeeeee;">
                    {{storePreferencesData.currencySymbol}} {{formatCurrency value}}
                  </td>
                </tr>
                {{/if}}
              {{/each}}
              {{#if value}}
              <tr>
                <td style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: 700; color: #000000; padding: 8px 0;">
                  Total
                </td>
                <td align="right" style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; font-weight: 700; color: #000000; padding: 8px 0;">
                  {{storePreferencesData.currencySymbol}} {{formatCurrency value}}
                </td>
              </tr>
              {{/if}}
            </table>

            <!-- ITEMS -->
            {{#richShippingData shippingData}}
              {{#group logisticsInfo by="addessId"}}
                {{#compare items.0.selectedDeliveryChannel '==' null}}
                  <div style="background-color: #f7f7f7; padding: 14px; margin-bottom: 12px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
                    <strong style="text-transform: uppercase; font-size: 11px; letter-spacing: 1pt; color: #999999;">{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Livraison{{else}}Delivery{{/eq}}</strong>
                    {{#if orders.0.giftRegistryData}}
                      <p style="margin: 6px 0 0;">{{orders.0.giftRegistryData.description}}</p>
                    {{else}}
                      {{#each ../../shippingData.availableAddresses}}
                        {{#eq ../addressId AddressId}}
                          <p style="margin: 6px 0 0;"><strong>{{receiverName}}</strong><br/>{{street}}, {{number}}{{#if complement}} — {{complement}}{{/if}}<br/>{{neighborhood}} — {{city}} — {{state}}<br/>{{postalCode}}</p>
                        {{/eq}}
                      {{/each}}
                    {{/if}}
                  </div>
                {{/compare}}
                {{#eq items.0.selectedDeliveryChannel "delivery"}}
                  <div style="background-color: #f7f7f7; padding: 14px; margin-bottom: 12px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
                    <strong style="text-transform: uppercase; font-size: 11px; letter-spacing: 1pt; color: #999999;">{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Livraison{{else}}Delivery{{/eq}}</strong>
                    {{#if orders.0.giftRegistryData}}
                      <p style="margin: 6px 0 0;">{{orders.0.giftRegistryData.description}}</p>
                    {{else}}
                      {{#each ../../shippingData.availableAddresses}}
                        {{#eq ../addressId AddressId}}
                          <p style="margin: 6px 0 0;"><strong>{{receiverName}}</strong><br/>{{street}}, {{number}}{{#if complement}} — {{complement}}{{/if}}<br/>{{neighborhood}} — {{city}} — {{state}}<br/>{{postalCode}}</p>
                        {{/eq}}
                      {{/each}}
                    {{/if}}
                  </div>
                {{/eq}}
                {{#eq items.0.selectedDeliveryChannel "pickup-in-point"}}
                  <div style="background-color: #f7f7f7; padding: 14px; margin-bottom: 12px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
                    <strong style="text-transform: uppercase; font-size: 11px; letter-spacing: 1pt; color: #999999;">{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Retrait{{else}}Pickup{{/eq}}</strong>
                    {{#each items.0.slas}}
                      {{#compare ../items.0.selectedSla '==' id}}
                        <p style="margin: 6px 0 0;"><strong>{{pickupStoreInfo.friendlyName}}</strong></p>
                        {{#with pickupStoreInfo.address}}
                          <p style="margin: 4px 0 0;">{{street}}, {{number}}{{#if complement}}, {{complement}}{{/if}}<br/>{{neighborhood}}</p>
                        {{/with}}
                      {{/compare}}
                    {{/each}}
                  </div>
                {{/eq}}

                {{#group items by="packageId"}}
                  {{#compare item.length '>' 1}}
                    <h3 style="font-family: Arial, Helvetica, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1pt; color: #999999; margin: 16px 0 8px;">
                      {{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Colis{{else}}Package{{/eq}} {{#math index '+' 1}}{{/math}}
                    </h3>
                  {{/compare}}

                  {{#each items}}
                    {{#compare @index '==' 0}}
                      {{#each ../../../../items}}
                        {{#eq id ../itemId}}
                          <div style="background-color: #f7f7f7; padding: 10px 14px; margin-bottom: 8px; font-family: Arial, Helvetica, sans-serif; font-size: 12px; color: #777777;">
                            {{#compare ../selectedDeliveryChannel "!=" "pickup-in-point"}}
                              {{#if ../deliveryWindow}}
                                {{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Livraison prévue le{{else}}Scheduled for{{/eq}}
                              {{else}}
                                {{../selectedSla}}
                              {{/if}}
                            {{/compare}}
                          </div>
                        {{/eq}}
                      {{/each}}
                    {{/compare}}
                  {{/each}}

                  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                    <tbody>
                    {{#each items}}
                      {{#each ../../../../items}}
                        {{#eq @index ../itemIndex}}
                        <tr>
                          <td width="64" valign="top" style="padding: 8px 12px 8px 0;">
                            <img src="{{imageUrl}}" width="64" alt="{{name}}" border="0" style="display: block; max-width: 64px; height: auto;"/>
                          </td>
                          <td valign="top" style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; padding: 8px 0;">
                            <p style="margin: 0 0 4px; font-weight: 700; color: #000000;">{{name}}</p>
                            <p style="margin: 0; color: #777777;">{{quantity}} un. — {{#if sellingPrice}}{{storePreferencesData.currencySymbol}} {{formatCurrency sellingPrice}}{{else}}{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Gratuit{{else}}Free{{/eq}}{{/if}}</p>
                          </td>
                        </tr>
                        {{/eq}}
                      {{/each}}
                    {{/each}}
                    </tbody>
                  </table>
                {{/group}}
              {{/group}}
            {{/richShippingData}}
          </td>
        </tr>
        <tr><td style="border-top: 1px solid #eeeeee; height: 1px; line-height: 1px; font-size: 1px;">&nbsp;</td></tr>
        {{/each}}

        <!-- CLOSING -->
        <tr>
          <td class="mobile-padding" style="padding: 32px 40px;">
            <p style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; line-height: 22px; color: #777777; margin: 0 0 8px;">
              {{#eq clientPreferencesData.locale "fr-CA"}}
                Les délais de livraison s'appliquent uniquement après confirmation du paiement.
              {{else}}
                Package delivery estimates apply only after payment is confirmed.
              {{/eq}}
            </p>
            <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0;">
              {{#eq clientPreferencesData.locale "fr-CA"}}Cordialement,{{else}}Kind regards,{{/eq}}<br/>
              {{_accountInfo.TradingName}}
            </p>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td style="background-color: #000000; padding: 32px 40px;" class="mobile-padding">
            <p style="margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; line-height: 18px; color: #777777; text-align: center;">&copy; {{_accountInfo.TradingName}}</p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
</body>
</html>
