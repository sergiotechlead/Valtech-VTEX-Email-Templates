<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional //EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:v="urn:schemas-microsoft-com:vml">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="x-apple-disable-message-reformatting"/>
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no"/>
  <title>{{_accountInfo.TradingName}}</title>
  <!--[if gte mso 9]>
  <xml>
    <o:OfficeDocumentSettings>
      <o:AllowPNG/>
      <o:PixelsPerInch>96</o:PixelsPerInch>
    </o:OfficeDocumentSettings>
  </xml>
  <![endif]-->
  <style type="text/css">
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }
    table { border-collapse: collapse !important; }
    body { margin: 0 !important; padding: 0 !important; background-color: #f4f4f4; }
    a[x-apple-data-detectors] {
      color: inherit !important; text-decoration: none !important;
      font-size: inherit !important; font-family: inherit !important;
      font-weight: inherit !important; line-height: inherit !important;
    }
    u + #body a { color: inherit; text-decoration: none; font-size: inherit; font-family: inherit; font-weight: inherit; line-height: inherit; }
    #MessageViewBody a { color: inherit; text-decoration: none; font-size: inherit; font-family: inherit; font-weight: inherit; line-height: inherit; }
    @media only screen and (max-width: 640px) {
      .email-container { width: 100% !important; }
      .mobile-padding { padding-left: 24px !important; padding-right: 24px !important; }
      .fluid { max-width: 100% !important; height: auto !important; }
      h1 { font-size: 26px !important; line-height: 34px !important; }
    }
  </style>
</head>
<body id="body" style="margin: 0; padding: 0; background-color: #f4f4f4;">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #f4f4f4;">
  <tr>
    <td align="center" valign="top" style="padding: 24px 0;">
      <table role="presentation" class="email-container" cellpadding="0" cellspacing="0" border="0" width="640" style="max-width: 640px; width: 100%; background-color: #ffffff; border-top: 7px solid #000000;">

        <!-- HEADER -->
        <tr>
          <td align="center" class="mobile-padding" style="padding: 32px 40px 24px; border-bottom: 1px solid #eeeeee;">
            <a href="https://{{_accountInfo.HostName}}" style="text-decoration: none; display: block;">
              <img src="https://licensemanager.vtex.com.br/api/site/pub/accounts/{{_accountInfo.Id}}/logos/show" width="172" alt="{{_accountInfo.TradingName}}" border="0" style="display: block; margin: 0 auto; max-width: 172px; height: auto;"/>
            </a>
          </td>
        </tr>

        <!-- TITLE -->
        <tr>
          <td align="center" class="mobile-padding" style="padding: 40px 40px 24px; border-bottom: 1px solid #eeeeee;">
            {{#compare items.length '==' shippingData.logisticsInfo.length}}
              {{#compare shippingData.logisticsInfo.0.selectedDeliveryChannel '==' 'pickup-in-point'}}
                <h1 style="font-family: Arial, Helvetica, sans-serif; font-size: 32px; line-height: 40px; font-weight: 700; color: #000000; margin: 0 0 12px;">
                  {{#eq clientPreferencesData.locale "fr-CA"}}Votre commande est prête pour le retrait.{{else}}Your order is available for pickup.{{/eq}}
                </h1>
              {{else}}
                <h1 style="font-family: Arial, Helvetica, sans-serif; font-size: 32px; line-height: 40px; font-weight: 700; color: #000000; margin: 0 0 12px;">
                  {{#eq clientPreferencesData.locale "fr-CA"}}Votre commande est en route.{{else}}Your order is on its way.{{/eq}}
                </h1>
              {{/compare}}
              <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #777777; margin: 0;">
                {{#eq clientPreferencesData.locale "fr-CA"}}Commande{{else}}Order{{/eq}} <strong>#{{sequence}}</strong>
              </p>
            {{else}}
              {{#compare shippingData.logisticsInfo.0.selectedDeliveryChannel '==' 'pickup-in-point'}}
                <h1 style="font-family: Arial, Helvetica, sans-serif; font-size: 32px; line-height: 40px; font-weight: 700; color: #000000; margin: 0 0 12px;">
                  {{#eq clientPreferencesData.locale "fr-CA"}}Un nouveau colis est prêt pour le retrait.{{else}}A new package is available for pickup.{{/eq}}
                </h1>
              {{else}}
                <h1 style="font-family: Arial, Helvetica, sans-serif; font-size: 32px; line-height: 40px; font-weight: 700; color: #000000; margin: 0 0 12px;">
                  {{#eq clientPreferencesData.locale "fr-CA"}}Un nouveau colis a été expédié.{{else}}A new package has shipped.{{/eq}}
                </h1>
              {{/compare}}
              <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; color: #777777; margin: 0 0 16px;">
                {{#eq clientPreferencesData.locale "fr-CA"}}Commande{{else}}Order{{/eq}} <strong>#{{orderId}}</strong>
              </p>
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                <tr>
                  <td style="background-color: #f7f7f7; padding: 14px 20px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; line-height: 22px; color: #333333; font-weight: 700; text-align: center;">
                    {{#eq clientPreferencesData.locale "fr-CA"}}
                      Votre commande contient plusieurs colis. Nous vous tiendrons informé(e) de l'avancement de chacun.
                    {{else}}
                      Your order has more than one package. We will update you about the progress of each of them.
                    {{/eq}}
                  </td>
                </tr>
              </table>
            {{/compare}}
          </td>
        </tr>

        <!-- GREETING -->
        <tr>
          <td class="mobile-padding" style="padding: 32px 40px 0;">
            <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 8px;">
              {{#if orders}}
                {{#if orders.0.clientProfileData.firstName}}
                  {{#compare orders.0.clientProfileData.firstName '!=' 'isAnonymous'}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Bonjour {{orders.0.clientProfileData.firstName}},{{else}}Hi {{orders.0.clientProfileData.firstName}},{{/eq}}
                  {{/compare}}
                {{/if}}
              {{else}}
                {{#if clientProfileData.firstName}}
                  {{#compare clientProfileData.firstName '!=' 'isAnonymous'}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Bonjour {{clientProfileData.firstName}},{{else}}Hi {{clientProfileData.firstName}},{{/eq}}
                  {{/compare}}
                {{/if}}
              {{/if}}
            </p>

            {{#compare shippingData.logisticsInfo.0.selectedDeliveryChannel '==' 'pickup-in-point'}}
              {{#compare items.length '==' shippingData.logisticsInfo.length}}
                <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 24px;">
                  {{#compare items.length '==' 1}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Votre article est prêt pour le retrait.{{else}}Your product is ready for pickup.{{/eq}}
                  {{/compare}}
                  {{#compare items.length '>' 1}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Vos articles sont prêts pour le retrait.{{else}}Your products are ready for pickup.{{/eq}}
                  {{/compare}}
                </p>
              {{/compare}}
              {{#compare items.length '!=' shippingData.logisticsInfo.length}}
                <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 24px;">
                  {{#compare items.length '==' 1}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}L'un de vos articles est prêt pour le retrait.{{else}}One of your products is ready for pickup.{{/eq}}
                  {{/compare}}
                  {{#compare items.length '>' 1}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Certains de vos articles sont prêts pour le retrait.{{else}}Some of your products are ready for pickup.{{/eq}}
                  {{/compare}}
                </p>
              {{/compare}}
            {{else}}
              {{#compare items.length '==' shippingData.logisticsInfo.length}}
                <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 24px;">
                  {{#compare items.length '==' 1}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Votre commande est en cours de livraison.{{else}}Your order is on the way. We hope you're as excited as we are!{{/eq}}
                  {{/compare}}
                  {{#compare items.length '>' 1}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Vos articles ont été remis au transporteur.{{else}}Your products have been tendered to the carrier.{{/eq}}
                  {{/compare}}
                </p>
              {{/compare}}
              {{#compare items.length '!=' shippingData.logisticsInfo.length}}
                <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0 0 24px;">
                  {{#compare items.length '==' 1}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}L'un de vos articles a été remis au transporteur.{{else}}One of the products in your order has been tendered to the carrier.{{/eq}}
                  {{/compare}}
                  {{#compare items.length '>' 1}}
                    {{#eq clientPreferencesData.locale "fr-CA"}}Certains articles de votre commande ont été remis au transporteur.{{else}}Some of the products in your order have been tendered to the carrier.{{/eq}}
                  {{/compare}}
                </p>
              {{/compare}}
            {{/compare}}
          </td>
        </tr>

        <!-- DIVIDER -->
        <tr><td style="border-top: 1px solid #eeeeee; height: 1px; line-height: 1px; font-size: 1px;">&nbsp;</td></tr>

        <!-- PACKAGE & ITEMS -->
        <tr>
          <td class="mobile-padding" style="padding: 32px 40px;">
            {{#richShippingData shippingData}}
              {{#group logisticsInfo by="addessId"}}
                <h3 style="font-family: Arial, Helvetica, sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1pt; color: #999999; margin: 0 0 12px;">
                  {{#eq ../../clientPreferencesData.locale "fr-CA"}}Colis{{else}}Package{{/eq}}
                </h3>

                {{#compare items.0.selectedDeliveryChannel '==' null}}
                  <div style="background-color: #f7f7f7; padding: 14px; margin-bottom: 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
                    {{#if orders.0.giftRegistryData}}
                      {{orders.0.giftRegistryData.description}}
                    {{else}}
                      {{#each ../../shippingData.availableAddresses}}
                        {{#eq ../addressId AddressId}}
                          <strong>{{receiverName}}</strong><br/>{{number}} {{street}}{{#if complement}}, {{complement}}{{/if}}<br/>{{city}}, {{state}} {{postalCode}}
                        {{/eq}}
                      {{/each}}
                    {{/if}}
                  </div>
                {{/compare}}

                {{#eq items.0.selectedDeliveryChannel "delivery"}}
                  <div style="background-color: #f7f7f7; padding: 14px; margin-bottom: 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
                    {{#if orders.0.giftRegistryData}}
                      {{orders.0.giftRegistryData.description}}
                    {{else}}
                      {{#each ../../shippingData.availableAddresses}}
                        {{#eq ../addressId AddressId}}
                          <strong>{{receiverName}}</strong><br/>{{number}} {{street}}{{#if complement}}, {{complement}}{{/if}}<br/>{{city}}, {{state}} {{postalCode}}
                        {{/eq}}
                      {{/each}}
                    {{/if}}
                  </div>
                {{/eq}}

                {{#eq items.0.selectedDeliveryChannel "pickup-in-point"}}
                  <div style="background-color: #f7f7f7; padding: 14px; margin-bottom: 16px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333;">
                    <strong>{{items.0.slas.0.pickupStoreInfo.friendlyName}}</strong>
                    {{#with items.0.slas.0.pickupStoreInfo.address}}
                      <br/>{{number}} {{street}}{{#if complement}}, {{complement}}{{/if}}
                    {{/with}}
                  </div>
                {{/eq}}

                {{#group items by="packageId"}}
                  {{#compare items.0.selectedDeliveryChannel '==' 'pickup-in-point'}}
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                      <tbody>
                      {{#each items}}
                        {{#each ../../../../items}}
                          {{#eq id ../itemId}}
                          <tr>
                            <td width="64" valign="top" style="padding: 8px 12px 8px 0;">
                              <img src="{{imageUrl}}" width="64" alt="{{name}}" border="0" style="display: block; max-width: 64px; height: auto;"/>
                            </td>
                            <td valign="top" style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; padding: 8px 0;">
                              <p style="margin: 0 0 4px; font-weight: 700; color: #000000;">{{name}}</p>
                              <p style="margin: 0; color: #777777;">{{quantity}} unit(s) — {{#if sellingPrice}}{{storePreferencesData.currencySymbol}} {{formatUSDCurrency sellingPrice}}{{else}}{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Gratuit{{else}}Free{{/eq}}{{/if}}</p>
                            </td>
                          </tr>
                          {{/eq}}
                        {{/each}}
                      {{/each}}
                      </tbody>
                    </table>
                  {{else}}
                    {{#each items}}
                      {{#compare @index '==' 0}}
                        <div style="background-color: #f7f7f7; padding: 10px 14px; margin-bottom: 8px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; color: #777777;">
                          {{#compare selectedDeliveryChannel "!=" "pickup-in-point"}}
                            {{#if deliveryWindow}}
                              {{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Livraison prévue le{{else}}Scheduled for{{/eq}}
                            {{else}}
                              {{selectedSla}}
                            {{/if}}
                          {{/compare}}
                          {{#if deliveryWindow}}
                            {{formatDate deliveryWindow.startDateUtc}} — {{formatTime deliveryWindow.startDateUtc}} / {{formatTime deliveryWindow.endDateUtc}}
                          {{else}}
                            {{#unless shippingEstimateDate}}
                              {{#eq shippingEstimateDays "0"}}
                                {{#eq selectedDeliveryChannel "pickup-in-point"}}{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}À partir d'aujourd'hui{{else}}After today{{/eq}}{{else}}{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Aujourd'hui{{else}}Today{{/eq}}{{/eq}}
                              {{else}}
                                {{#eq selectedDeliveryChannel "pickup-in-point"}}{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}À partir de{{else}}After{{/eq}}{{else}}{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}En{{else}}In up to{{/eq}}{{/eq}}
                                {{#compare shippingEstimateDays ">" "1"}}
                                  {{#eq shippingEstimateDaysType "bd"}}{{shippingEstimateDays}} {{#eq ../../../../clientPreferencesData.locale "fr-CA"}}jours ouvrables{{else}}business days{{/eq}}{{/eq}}
                                  {{#eq shippingEstimateDaysType "d"}}{{shippingEstimateDays}} {{#eq ../../../../clientPreferencesData.locale "fr-CA"}}jours{{else}}days{{/eq}}{{/eq}}
                                  {{#eq shippingEstimateDaysType "h"}}{{shippingEstimateDays}} {{#eq ../../../../clientPreferencesData.locale "fr-CA"}}heures{{else}}hours{{/eq}}{{/eq}}
                                {{else}}
                                  {{#eq shippingEstimateDaysType "bd"}}{{shippingEstimateDays}} {{#eq ../../../../clientPreferencesData.locale "fr-CA"}}jour ouvrable{{else}}business day{{/eq}}{{/eq}}
                                  {{#eq shippingEstimateDaysType "d"}}{{shippingEstimateDays}} {{#eq ../../../../clientPreferencesData.locale "fr-CA"}}jour{{else}}day{{/eq}}{{/eq}}
                                  {{#eq shippingEstimateDaysType "h"}}{{shippingEstimateDays}} {{#eq ../../../../clientPreferencesData.locale "fr-CA"}}heure{{else}}hour{{/eq}}{{/eq}}
                                {{/compare}}
                              {{/eq}}
                            {{else}}
                              {{#eq deliveryChannel "pickup-in-point"}}{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}À partir de{{else}}After{{/eq}}{{else}}{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Jusqu'au{{else}}By{{/eq}}{{/eq}} {{formatDate shippingEstimateDate}}
                            {{/unless}}
                          {{/if}}
                        </div>
                      {{/compare}}
                    {{/each}}

                    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                      <tbody>
                      {{#each items}}
                        {{#each ../../../../items}}
                          {{#eq id ../itemId}}
                          <tr>
                            <td width="64" valign="top" style="padding: 8px 12px 8px 0;">
                              <img src="{{imageUrl}}" width="64" alt="{{name}}" border="0" style="display: block; max-width: 64px; height: auto;"/>
                            </td>
                            <td valign="top" style="font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333333; padding: 8px 0;">
                              <p style="margin: 0 0 4px; font-weight: 700; color: #000000;">{{name}}</p>
                              <p style="margin: 0; color: #777777;">{{quantity}} unit(s) — {{#if sellingPrice}}{{storePreferencesData.currencySymbol}} {{formatUSDCurrency sellingPrice}}{{else}}{{#eq ../../../../clientPreferencesData.locale "fr-CA"}}Gratuit{{else}}Free{{/eq}}{{/if}}</p>
                            </td>
                          </tr>
                          {{/eq}}
                        {{/each}}
                      {{/each}}
                      </tbody>
                    </table>
                  {{/compare}}
                {{/group}}
              {{/group}}
            {{/richShippingData}}
          </td>
        </tr>

        <!-- DIVIDER -->
        <tr><td style="border-top: 1px solid #eeeeee; height: 1px; line-height: 1px; font-size: 1px;">&nbsp;</td></tr>

        <!-- CLOSING -->
        <tr>
          <td class="mobile-padding" style="padding: 32px 40px;">
            <p style="font-family: Arial, Helvetica, sans-serif; font-size: 15px; line-height: 24px; color: #333333; margin: 0;">
              {{#eq clientPreferencesData.locale "fr-CA"}}Cordialement,{{else}}Kind regards,{{/eq}}<br/>
              {{_accountInfo.TradingName}}
            </p>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td style="background-color: #000000; padding: 32px 40px;" class="mobile-padding">
            <p style="margin: 0; font-family: Arial, Helvetica, sans-serif; font-size: 12px; line-height: 18px; color: #777777; text-align: center;">&copy; {{_accountInfo.TradingName}}</p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
</body>
</html>
